{% comment %}
  Section : product-elinea-custom
  Elinea Paris — Page produit haute conversion
{% endcomment %}

<style>
:root{
  --pink:#e87aa5;
  --pink-dark:#c2104a;
  --pink-light:#fde8f2;
  --rose:#ffc5d5;
  --dark:#0f0208;
  --text:#2a1520;
  --gold:#c9936a;
}
*{margin:0;padding:0;box-sizing:border-box;}
html{scroll-behavior:smooth;}
body{font-family:'Nunito',sans-serif;color:var(--text);background:#fff;overflow-x:hidden;font-size:16px;}

/* ══ STICKY TOP BAR ══ */
.top-bar{
  position:sticky;top:0;z-index:999;
  background:var(--dark);color:white;
  padding:0;overflow:hidden;
}
.top-bar-inner{
  display:flex;align-items:center;justify-content:center;
  gap:40px;padding:10px 20px;
  font-size:.78rem;font-weight:800;letter-spacing:.5px;
  white-space:nowrap;
}
.top-bar-item{display:flex;align-items:center;gap:6px;}
.top-bar-item span{color:var(--rose);}
.cd-wrap{display:flex;align-items:center;gap:4px;margin-left:4px;}
.cd-wrap b{
  background:var(--pink-dark);border-radius:6px;
  padding:2px 8px;font-size:.92rem;
  min-width:28px;text-align:center;
}

/* ══ HEADER ══ */
.header{
  padding:16px 40px;
  display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid #f0e0e8;
}
.logo{font-family:'Playfair Display',serif;font-size:1.6rem;font-weight:900;color:var(--dark);letter-spacing:2px;text-decoration:none;}
.logo sub{font-size:.55em;color:var(--pink-dark);letter-spacing:4px;font-family:'Nunito',sans-serif;font-weight:900;text-transform:uppercase;}
.header-trust{display:flex;gap:20px;}
.ht{font-size:.75rem;font-weight:700;color:#aaa;display:flex;align-items:center;gap:4px;}

/* ══ HERO ACCROCHE (NOUVEAU) ══ */
.hero-hook{
  background:linear-gradient(135deg,#fce0e8 0%,#f5a8c0 60%,#e87aa5 100%);
  text-align:center;padding:32px 20px 24px;
  position:relative;overflow:hidden;
}
.hook-tag{
  display:inline-block;background:white;
  color:var(--pink-dark);font-size:.72rem;font-weight:900;
  text-transform:uppercase;letter-spacing:2px;
  padding:6px 18px;border-radius:30px;margin-bottom:14px;
  box-shadow:0 2px 12px rgba(0,0,0,.1);
}
.hook-h1{
  font-family:'Playfair Display',serif;
  font-size:clamp(2rem,5vw,3.2rem);font-weight:900;
  color:white;line-height:1.1;
  text-shadow:0 4px 20px rgba(160,20,70,.3);
  margin-bottom:10px;
}
.hook-sub{font-size:1.05rem;color:rgba(255,255,255,.85);font-weight:600;}

/* ══ PRODUCT SECTION ══ */
.product-wrap{
  max-width:1200px;margin:0 auto;
  display:grid;grid-template-columns:1fr 1fr;
  gap:60px;padding:60px 40px;align-items:start;
}

/* ── Galerie ── */
.gallery{position:sticky;top:60px;}
.gallery-main{
  border-radius:24px;overflow:hidden;
  background:var(--pink-light);
  margin-bottom:14px;cursor:zoom-in;
  aspect-ratio:1;display:flex;align-items:center;justify-content:center;
}
.gallery-main img{width:100%;height:100%;object-fit:cover;transition:transform .3s;}
.gallery-main:hover img{transform:scale(1.04);}
.gallery-thumbs{display:flex;gap:10px;flex-wrap:wrap;}
.thumb{
  width:80px;height:80px;border-radius:12px;
  overflow:hidden;cursor:pointer;border:2.5px solid transparent;
  transition:border-color .2s;flex-shrink:0;
  background:var(--pink-light);
}
.thumb.active,.thumb:hover{border-color:var(--pink-dark);}
.thumb img{width:100%;height:100%;object-fit:cover;}

/* ── Info produit ── */
.prod-info{}
.brand-flag{
  display:flex;align-items:center;gap:8px;
  margin-bottom:12px;
}
.flag-txt{font-size:.75rem;font-weight:800;color:#aaa;letter-spacing:1px;text-transform:uppercase;}
.stars-row{display:flex;align-items:center;gap:10px;margin-bottom:16px;}
.stars{color:#f5c842;font-size:1.1rem;letter-spacing:1px;}
.star-txt{font-size:.88rem;color:#888;font-weight:700;}
.star-txt a{color:var(--pink-dark);text-decoration:none;}

.prod-title{
  font-family:'Playfair Display',serif;
  font-size:2.4rem;font-weight:900;color:var(--dark);
  line-height:1.1;margin-bottom:14px;
}
.prod-bullets{
  list-style:none;margin-bottom:24px;
  display:flex;flex-direction:column;gap:8px;
}
.prod-bullets li{
  display:flex;align-items:center;gap:10px;
  font-size:.95rem;font-weight:700;color:var(--text);
}
.prod-bullets li::before{
  content:'✓';background:var(--pink-dark);color:white;
  width:22px;height:22px;border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:.7rem;font-weight:900;flex-shrink:0;
}

/* ── Prix (AMÉLIORÉ) ── */
.price-block{
  background:var(--pink-light);border-radius:20px;
  padding:20px 24px;margin-bottom:20px;
  border:1.5px solid #f5b8d0;
}
.price-row{display:flex;align-items:center;gap:14px;margin-bottom:8px;}
.p-old{font-size:1.3rem;color:#bbb;text-decoration:line-through;font-weight:700;}
.p-new{font-size:3rem;font-weight:900;color:var(--pink-dark);line-height:1;}
.p-badge{
  background:var(--pink-dark);color:white;
  font-size:1rem;font-weight:900;
  padding:6px 16px;border-radius:12px;
  animation:pulse 2s infinite;
}
@keyframes pulse{0%,100%{transform:scale(1);}50%{transform:scale(1.06);}}
.price-note{font-size:.82rem;color:#c04070;font-weight:700;}

/* ── Stock ── */
.stock-block{margin-bottom:20px;}
.stock-label{
  display:flex;justify-content:space-between;
  font-size:.82rem;font-weight:800;margin-bottom:6px;
}
.stock-label .warn{color:var(--pink-dark);}
.stock-label .count{color:#888;}
.stock-bar{height:10px;background:#fce0e8;border-radius:10px;overflow:hidden;}
.stock-fill{height:100%;width:82%;background:linear-gradient(90deg,#e83570,var(--pink-dark));border-radius:10px;}

/* ── CTA AMÉLIORÉ ── */
.cta-main{
  display:block;width:100%;
  background:linear-gradient(135deg,var(--pink-dark) 0%,#e83570 100%);
  color:white;font-family:'Nunito',sans-serif;
  font-size:1.2rem;font-weight:900;
  padding:22px 30px;border-radius:50px;border:none;cursor:pointer;
  text-align:center;text-decoration:none;
  box-shadow:0 8px 30px rgba(180,20,70,.4);
  transition:transform .2s,box-shadow .2s;
  letter-spacing:.5px;
  position:relative;overflow:hidden;
  margin-bottom:12px;
}
.cta-main::after{
  content:'';position:absolute;top:-50%;left:-60%;
  width:40%;height:200%;
  background:rgba(255,255,255,.15);
  transform:skewX(-20deg);
  animation:shine 3s infinite;
}
@keyframes shine{0%{left:-60%;}100%{left:120%;}}
.cta-main:hover{transform:translateY(-3px);box-shadow:0 12px 40px rgba(180,20,70,.5);}
.cta-sub{text-align:center;font-size:.82rem;color:#888;font-weight:700;margin-bottom:20px;}

/* Garanties */
.guarantees{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:10px;margin-bottom:24px;
}
.g-item{
  background:#fafafa;border-radius:12px;
  padding:12px 10px;text-align:center;
  border:1px solid #f0e0e8;
}
.g-icon{font-size:1.4rem;margin-bottom:4px;}
.g-txt{font-size:.72rem;font-weight:800;color:#888;}

/* Avis mini */
.mini-review{
  background:white;border:1.5px solid #f0e0e8;
  border-radius:16px;padding:16px 18px;
  display:flex;gap:14px;align-items:flex-start;
}
.m-av{
  width:44px;height:44px;border-radius:50%;
  overflow:hidden;flex-shrink:0;
  background:var(--pink-light);
}
.m-av img{width:100%;height:100%;object-fit:cover;}
.m-stars{color:#f5c842;font-size:.85rem;margin-bottom:3px;}
.m-text{font-size:.88rem;color:#555;font-style:italic;line-height:1.5;margin-bottom:4px;}
.m-author{font-size:.78rem;font-weight:800;color:#aaa;}

/* ══ PRESSE ══ */
.presse{
  border-top:1px solid #f0e0e8;border-bottom:1px solid #f0e0e8;
  padding:24px 40px;text-align:center;
  display:flex;align-items:center;justify-content:center;gap:40px;
  flex-wrap:wrap;background:#fafafa;
}
.presse-label{font-size:.72rem;font-weight:900;text-transform:uppercase;letter-spacing:2px;color:#ccc;}
.presse img{height:24px;opacity:.4;filter:grayscale(1);}

/* ══ BENEFITS IMAGE ══ */
.benefits-img{width:100%;max-width:900px;margin:0 auto;display:block;border-radius:24px;}

/* ══ BEFORE/AFTER ══ */
.section{max-width:1100px;margin:0 auto;padding:70px 40px;}
.section-tag{
  display:inline-block;background:var(--pink-light);
  color:var(--pink-dark);font-size:.72rem;font-weight:900;
  text-transform:uppercase;letter-spacing:2px;
  padding:6px 16px;border-radius:20px;margin-bottom:16px;
}
.section-h2{
  font-family:'Playfair Display',serif;
  font-size:clamp(1.8rem,4vw,2.6rem);font-weight:900;
  color:var(--dark);margin-bottom:10px;line-height:1.15;
}
.section-h2 span{color:var(--pink-dark);}
.section-sub{font-size:1rem;color:#888;line-height:1.7;max-width:600px;margin-bottom:40px;}

.ba-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
.ba-card{border-radius:20px;overflow:hidden;box-shadow:0 4px 20px rgba(0,0,0,.08);}
.ba-card img{width:100%;display:block;}

/* ══ STATS ══ */
.stats-section{
  background:linear-gradient(135deg,var(--dark),#3a0820);
  padding:70px 40px;
}
.stats-inner{max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:60px;align-items:center;}
.stat-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;}
.stat-card{background:rgba(255,255,255,.07);border-radius:20px;padding:28px 20px;text-align:center;border:1px solid rgba(255,255,255,.08);}
.stat-num{font-family:'Playfair Display',serif;font-size:2.8rem;font-weight:900;color:white;line-height:1;margin-bottom:6px;}
.stat-num span{color:var(--rose);}
.stat-label{font-size:.82rem;color:rgba(255,255,255,.5);font-weight:700;}
.stats-text .section-h2{color:white;}
.stats-text .section-h2 span{color:var(--rose);}
.stats-text .section-sub{color:rgba(255,255,255,.5);}
.stats-cta{
  display:inline-block;
  background:linear-gradient(135deg,var(--pink-dark),#e83570);
  color:white;font-family:'Nunito',sans-serif;
  font-size:1rem;font-weight:900;padding:16px 40px;
  border-radius:50px;text-decoration:none;
  box-shadow:0 6px 24px rgba(180,20,70,.4);
  margin-top:28px;
}

/* ══ REVIEWS ══ */
.reviews-section{background:var(--pink-light);padding:70px 40px;}
.reviews-inner{max-width:1100px;margin:0 auto;}
.review-header{text-align:center;margin-bottom:40px;}
.rating-big{font-size:4rem;font-weight:900;color:var(--dark);line-height:1;}
.rating-stars{color:#f5c842;font-size:1.8rem;letter-spacing:3px;margin:8px 0;}
.rating-count{font-size:.88rem;color:#888;font-weight:700;}
.reviews-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:20px;}
.r-card{background:white;border-radius:20px;padding:28px;box-shadow:0 4px 20px rgba(180,80,120,.08);}
.r-stars{color:#f5c842;font-size:.9rem;margin-bottom:10px;}
.r-text{font-size:.92rem;color:#555;line-height:1.65;margin-bottom:16px;font-style:italic;}
.r-author{display:flex;align-items:center;gap:12px;}
.r-av{width:40px;height:40px;border-radius:50%;background:linear-gradient(135deg,var(--pink),var(--pink-dark));display:flex;align-items:center;justify-content:center;font-weight:900;color:white;font-size:.82rem;overflow:hidden;}
.r-av img{width:100%;height:100%;object-fit:cover;}
.r-name{font-size:.85rem;font-weight:800;color:var(--dark);}
.r-date{font-size:.75rem;color:#aaa;}

/* ══ BUNDLE ══ */
.bundle-section{padding:70px 40px;background:white;}
.bundle-inner{max-width:900px;margin:0 auto;}
.bundle-box{
  background:linear-gradient(135deg,var(--dark),#3a0820);
  border-radius:32px;padding:50px;text-align:center;
}
.bundle-box .section-h2{color:white;margin-bottom:8px;}
.bundle-box .section-h2 span{color:var(--rose);}
.bundle-sub{color:rgba(255,255,255,.5);margin-bottom:40px;font-size:.95rem;}
.bundle-products{display:flex;align-items:center;justify-content:center;gap:24px;margin-bottom:36px;}
.bp{
  background:rgba(255,255,255,.07);border-radius:20px;
  padding:24px;flex:1;max-width:240px;text-align:center;
}
.bp img{width:80%;max-width:160px;filter:drop-shadow(0 10px 30px rgba(0,0,0,.5));margin-bottom:14px;}
.bp h4{color:white;font-size:.95rem;font-weight:800;margin-bottom:4px;}
.bp .bp-old{color:rgba(255,255,255,.3);text-decoration:line-through;font-size:.85rem;}
.plus{font-size:2.5rem;font-weight:900;color:rgba(201,147,106,.6);flex-shrink:0;}
.bundle-prices{margin-bottom:28px;}
.b-old{font-size:1.2rem;color:rgba(255,255,255,.3);text-decoration:line-through;font-weight:700;margin-bottom:4px;}
.b-new{font-size:3.5rem;font-weight:900;color:white;line-height:1;margin-bottom:10px;}
.b-save{
  display:inline-block;background:var(--pink-dark);color:white;
  font-size:.9rem;font-weight:900;padding:6px 18px;border-radius:10px;
}
.bundle-cta{
  display:inline-block;
  background:linear-gradient(135deg,var(--gold),#e0b090);
  color:white;font-family:'Nunito',sans-serif;
  font-size:1.1rem;font-weight:900;padding:18px 52px;
  border-radius:50px;text-decoration:none;
  box-shadow:0 8px 30px rgba(180,100,40,.3);
}

/* ══ FAQ ══ */
.faq-section{padding:70px 40px;background:#fafafa;}
.faq-inner{max-width:720px;margin:0 auto;}
.faq-item{
  background:white;border-radius:16px;
  margin-bottom:12px;overflow:hidden;
  box-shadow:0 2px 12px rgba(180,80,120,.06);
  border:1px solid #f0e0e8;
}
.faq-q{
  padding:22px 26px;font-weight:800;font-size:.97rem;color:var(--dark);
  cursor:pointer;display:flex;justify-content:space-between;align-items:center;
  transition:background .2s;
}
.faq-q:hover{background:var(--pink-light);}
.faq-icon{
  width:28px;height:28px;border-radius:50%;
  background:var(--pink-light);color:var(--pink-dark);
  display:flex;align-items:center;justify-content:center;
  font-size:1.2rem;font-weight:900;flex-shrink:0;
  transition:transform .3s,background .2s;
}
.faq-item.open .faq-icon{transform:rotate(45deg);background:var(--pink-dark);color:white;}
.faq-a{
  max-height:0;overflow:hidden;
  transition:max-height .4s ease,padding .3s;
  font-size:.9rem;color:#666;line-height:1.75;
  padding:0 26px;
}
.faq-item.open .faq-a{max-height:200px;padding:0 26px 22px;}

/* ══ BOTTOM CTA ══ */
.bottom-cta{
  background:linear-gradient(135deg,#fce0e8,var(--rose));
  padding:70px 40px;text-align:center;
}
.bottom-cta .section-h2{margin-bottom:10px;}
.bottom-cta-sub{color:#888;font-size:1rem;margin-bottom:36px;}
.bottom-cta-btn{
  display:inline-block;
  background:linear-gradient(135deg,var(--pink-dark),#e83570);
  color:white;font-family:'Nunito',sans-serif;
  font-size:1.2rem;font-weight:900;padding:22px 60px;
  border-radius:50px;text-decoration:none;
  box-shadow:0 8px 30px rgba(180,20,70,.4);
  transition:transform .2s;
}
.bottom-cta-btn:hover{transform:translateY(-3px);}
.bottom-cta-trust{margin-top:20px;display:flex;justify-content:center;gap:28px;flex-wrap:wrap;}
.bct{font-size:.82rem;font-weight:700;color:#aaa;}

/* ══ FOOTER ══ */
footer{background:var(--dark);padding:40px;text-align:center;}
footer .f-logo{font-family:'Playfair Display',serif;font-size:1.4rem;font-weight:900;color:white;letter-spacing:2px;margin-bottom:16px;}
footer p{color:rgba(255,255,255,.3);font-size:.78rem;line-height:1.6;}
footer a{color:rgba(255,255,255,.3);text-decoration:none;}

/* ══ MOBILE ══ */
@media(max-width:900px){
  .product-wrap{grid-template-columns:1fr;padding:30px 20px;gap:30px;}
  .gallery{position:static;}
  .stats-inner,.ba-grid,.reviews-grid,.stat-grid{grid-template-columns:1fr;}
  .bundle-products{flex-direction:column;align-items:center;}
  .section,.reviews-section,.bundle-section,.faq-section,.stats-section,.bottom-cta{padding:50px 20px;}
  .header{padding:14px 20px;}
  .presse{gap:20px;padding:20px;}
  .guarantees{grid-template-columns:1fr 1fr;}
  .top-bar-inner{gap:16px;font-size:.7rem;}
}

.fade-in{opacity:0;transform:translateY(24px);transition:opacity .6s ease,transform .6s ease;}
.fade-in.visible{opacity:1;transform:translateY(0);}
</style>

