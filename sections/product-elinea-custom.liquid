<script>
// Countdown
function startCd(t){
  const m=document.getElementById('cm'),s=document.getElementById('cs');
  setInterval(()=>{
    if(t<=0)t=9*60+59; t--;
    m.textContent=String(Math.floor(t/60)).padStart(2,'0');
    s.textContent=String(t%60).padStart(2,'0');
  },1000);
}
startCd(9*60+59);

// Galerie
function setImg(el, src){
  document.getElementById('main-photo').src=src;
  document.querySelectorAll('.thumb').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
}

// FAQ
document.querySelectorAll('.faq-q').forEach(q=>{
  q.addEventListener('click',()=>{
    const item=q.parentElement, was=item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));
    if(!was) item.classList.add('open');
  });
});

// Scroll animations
const obs=new IntersectionObserver(entries=>entries.forEach(e=>{
  if(e.isIntersecting) e.target.classList.add('visible');
}),{threshold:.1});
document.querySelectorAll('.fade-in').forEach(el=>obs.observe(el));
</script>

<script>
// ══ COUNTDOWN ══
function startCd(t){
  const m=document.getElementById('cm'),s=document.getElementById('cs');
  if(!m||!s) return;
  setInterval(()=>{
    if(t<=0)t=9*60+59; t--;
    m.textContent=String(Math.floor(t/60)).padStart(2,'0');
    s.textContent=String(t%60).padStart(2,'0');
  },1000);
}
startCd(9*60+59);

// ══ GALERIE ══
function setImg(el, src){
  const main=document.getElementById('main-photo');
  if(main) main.src=src;
  document.querySelectorAll('.thumb').forEach(t=>t.classList.remove('active'));
  el.classList.add('active');
}

// ══ FAQ ══
document.querySelectorAll('.faq-q').forEach(q=>{
  q.addEventListener('click',()=>{
    const item=q.parentElement, was=item.classList.contains('open');
    document.querySelectorAll('.faq-item').forEach(i=>i.classList.remove('open'));
    if(!was) item.classList.add('open');
  });
});

// ══ SCROLL ANIMATIONS ══
const obs=new IntersectionObserver(entries=>entries.forEach(e=>{
  if(e.isIntersecting) e.target.classList.add('visible');
}),{threshold:.1});
document.querySelectorAll('.fade-in').forEach(el=>obs.observe(el));

// ══ VARIANTES (Blanc / Rose) ══
const VARIANTS = {{ product.variants | json }};
let selectedVariantId = {{ product.variants.first.id }};

// Créer les boutons variantes si plusieurs variantes
(function(){
  if(!VARIANTS || VARIANTS.length <= 1) return;
  const wrap = document.getElementById('variant-selector');
  if(!wrap) return;
  VARIANTS.forEach(v => {
    const btn = document.createElement('button');
    btn.className = 'variant-btn' + (v.id === selectedVariantId ? ' active' : '');
    btn.textContent = v.title;
    btn.dataset.variantId = v.id;
    btn.addEventListener('click', function(){
      selectedVariantId = parseInt(this.dataset.variantId);
      document.querySelectorAll('.variant-btn').forEach(b => b.classList.remove('active'));
      this.classList.add('active');
    });
    wrap.appendChild(btn);
  });
})();

// ══ ADD TO CART — Épilateur seul ══
function addToCart(variantId, btnSelectors) {
  const btns = document.querySelectorAll(btnSelectors);
  btns.forEach(b => {
    b.style.opacity = '.6';
    b.style.pointerEvents = 'none';
    b.dataset.orig = b.innerHTML;
    b.innerHTML = '⏳ Ajout en cours...';
  });
  fetch('/cart/add.js', {
    method: 'POST',
    headers: {'Content-Type': 'application/json'},
    body: JSON.stringify({items: [{id: variantId, quantity: 1}]})
  })
  .then(r => r.json())
  .then(() => { window.location.href = '/cart'; })
  .catch(() => { window.location.href = '/cart'; });
}

// ══ ADD TO CART — Bundle épilateur + gant offert ══
function addBundle(epilVariantId) {
  const btns = document.querySelectorAll('.bundle-cta');
  btns.forEach(b => {
    b.style.opacity = '.6';
    b.style.pointerEvents = 'none';
    b.innerHTML = '⏳ Ajout en cours...';
  });

  // Récupérer la variante du gant par son handle
  fetch('/products/gant-exfoliant-en-soie-corps-copie.js')
    .then(r => {
      if(!r.ok) throw new Error('handle introuvable');
      return r.json();
    })
    .then(data => {
      const gantId = data.variants[0].id;
      return fetch('/cart/add.js', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({
          items: [
            {id: epilVariantId, quantity: 1},
            {id: gantId, quantity: 1}
          ]
        })
      });
    })
    .then(() => { window.location.href = '/cart'; })
    .catch(err => {
      console.warn('Gant non trouvé, ajout épilateur seul:', err);
      fetch('/cart/add.js', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({items: [{id: epilVariantId, quantity: 1}]})
      }).then(() => { window.location.href = '/cart'; });
    });
}

// Boutons CTA principaux
document.getElementById('add-to-cart-main')?.addEventListener('click', function(e){
  e.preventDefault();
  addToCart(selectedVariantId, '#add-to-cart-main');
});
document.getElementById('add-to-cart-bottom')?.addEventListener('click', function(e){
  e.preventDefault();
  addToCart(selectedVariantId, '#add-to-cart-bottom');
});

// Bouton bundle gant offert
document.querySelectorAll('.bundle-cta').forEach(btn => {
  btn.addEventListener('click', function(e){
    e.preventDefault();
    addBundle(selectedVariantId);
  });
});
</script>

