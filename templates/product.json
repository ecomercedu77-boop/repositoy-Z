          "settings": {
            "liquid": "<!-- =========================================================\nBANNIÈRE AVIS (AUTO + DOTS) - MOBILE FRIENDLY\n========================================================= -->\n\n<style>\n  .elxR-banner{\n    font-family:-apple-system,BlinkMacSystemFont,\"Helvetica Neue\",Arial,sans-serif;\n    max-width:980px;margin:18px auto;padding:0 16px;color:#111;\n  }\n\n  .elxR-toprow{\n    display:flex;align-items:center;justify-content:space-between;\n    gap:12px;flex-wrap:wrap;margin-bottom:12px;\n  }\n\n  .elxR-reviews-link{display:inline-flex;align-items:center;gap:10px;color:#111;font-size:14px;font-weight:600;}\n  .elxR-reviews-link a{color:#111;text-decoration:underline;}\n  .elxR-stars{color:#22a06b;letter-spacing:2px;font-size:14px;display:inline-flex;align-items:center;gap:8px;}\n  .elxR-rating{font-size:13px;font-weight:700;color:#111;}\n  .elxR-flag{display:inline-flex;align-items:center;gap:8px;font-size:14px;font-weight:600;white-space:nowrap;}\n\n  .elxR-quote{\n    background:#f6f0e7;border:1px solid rgba(0,0,0,.08);\n    border-radius:12px;padding:12px 12px;\n    display:flex;align-items:flex-start;gap:10px;\n    position:relative;margin-bottom:12px;\n  }\n\n  .elxR-quote .avatar{\n    width:40px;height:40px;border-radius:999px;object-fit:cover;\n    border:1px solid rgba(0,0,0,.08);flex:0 0 auto;\n  }\n\n  .elxR-quote .qwrap{min-width:0; padding-right:56px;} /* réserve place pour les dots */\n  .elxR-quote .qtitle{\n    font-weight:700;font-size:14px;line-height:1.25;margin:0 0 4px;\n    word-break:break-word;\n  }\n  .elxR-quote .qmeta{font-size:12.5px;color:#555;margin:0;line-height:1.2;}\n\n  .elxR-dots{\n    display:flex;gap:7px;\n    position:absolute;right:12px;top:50%;\n    transform:translateY(-50%);\n  }\n  .elxR-dot{width:7px;height:7px;border-radius:50%;background:rgba(0,0,0,.25);cursor:pointer;}\n  .elxR-dot.active{background:rgba(0,0,0,.85);}\n\n  .elxR-title{\n    font-family:Georgia,\"Times New Roman\",serif;\n    font-size:44px;font-weight:500;margin:8px 0 6px;\n    line-height:1.05;\n  }\n  .elxR-hr{height:1px;background:rgba(0,0,0,.08);border:0;margin:12px 0 14px;}\n\n  .elxR-bullets{list-style:none;padding:0;margin:0;display:grid;gap:10px;}\n  .elxR-bullets li{display:flex;gap:10px;font-size:14px;line-height:1.25;}\n  .elxR-bullets li strong{font-weight:800;}\n\n  /* ✅ MOBILE OPTI */\n  @media (max-width:640px){\n    .elxR-banner{padding:0 12px;margin:14px auto;}\n    .elxR-toprow{flex-direction:column;align-items:flex-start;gap:8px;}\n    .elxR-title{font-size:30px;line-height:1.08;margin-top:6px;}\n    .elxR-quote{padding:11px 11px;}\n    .elxR-quote .avatar{width:36px;height:36px;}\n    .elxR-quote .qwrap{padding-right:0;} /* les dots descendent en bas */\n    .elxR-dots{\n      position:static;transform:none;margin-top:10px;\n      justify-content:flex-start;\n    }\n  }\n</style>\n\n<section class=\"elxR-banner\" data-elx-reviews>\n\n  <div class=\"elxR-toprow\">\n    <div class=\"elxR-reviews-link\">\n      <span class=\"elxR-stars\">\n        <span>★★★★<span style=\"opacity:.55;\">★</span></span>\n        <span class=\"elxR-rating\">4.7</span>\n      </span>\n      <a href=\"#avis\">1800 avis</a>\n    </div>\n\n    <div class=\"elxR-flag\">\n      <span style=\"font-size:18px;\">🇫🇷</span>\n      <span>Marque française</span>\n    </div>\n  </div>\n\n  <div class=\"elxR-quote\">\n    <img class=\"avatar\" data-elx-avatar src=\"https://i.pravatar.cc/84?img=15\" alt=\"Avis client\">\n    <div class=\"qwrap\">\n      <p class=\"qtitle\" data-elx-quote>Zéro irritation, hyper doux. Je recommande à 100%.</p>\n      <p class=\"qmeta\" data-elx-meta></p>\n\n      <div class=\"elxR-dots\" aria-label=\"Avis clients\">\n        <span class=\"elxR-dot active\" data-idx=\"0\" role=\"button\" tabindex=\"0\" aria-label=\"Avis 1\"></span>\n        <span class=\"elxR-dot\" data-idx=\"1\" role=\"button\" tabindex=\"0\" aria-label=\"Avis 2\"></span>\n        <span class=\"elxR-dot\" data-idx=\"2\" role=\"button\" tabindex=\"0\" aria-label=\"Avis 3\"></span>\n      </div>\n    </div>\n  </div>\n\n  <h1 class=\"elxR-title\">Rasoir Électrique Précision</h1>\n  <hr class=\"elxR-hr\">\n\n  <ul class=\"elxR-bullets\">\n    <li>✔ <strong>Rasage doux</strong> : évite irritations & coupures</li>\n    <li>✔ <strong>Zones sensibles</strong> : bikini, aisselles, corps</li>\n    <li>✔ <strong>Peau plus nette</strong> : aide à prévenir les poils incarnés</li>\n  </ul>\n\n</section>\n\n<script>\n(function(){\n  const section = document.querySelector('[data-elx-reviews]');\n  if(!section) return;\n\n  const quoteEl = section.querySelector('[data-elx-quote]');\n  const metaEl  = section.querySelector('[data-elx-meta]');\n  const avatarEl = section.querySelector('[data-elx-avatar]');\n  const dots = section.querySelectorAll('.elxR-dot');\n\n  const slides = [\n    {quote:\"Zéro irritation, hyper doux. Je recommande à 100%.\", name:\"Claire M.\", city:\"Paris\", days:6, avatar:\"https://i.pravatar.cc/84?img=15\"},\n    {quote:\"Super précis sur les zones sensibles.\", name:\"Sophie L.\", city:\"Lyon\", days:12, avatar:\"https://i.pravatar.cc/84?img=28\"},\n    {quote:\"Peau nette et moins de poils incarnés.\", name:\"Émilie R.\", city:\"Nice\", days:3, avatar:\"https://i.pravatar.cc/84?img=45\"}\n  ];\n\n  let current = 0;\n\n  function render(i){\n    const s = slides[i];\n    quoteEl.textContent = s.quote;\n    avatarEl.src = s.avatar;\n    metaEl.textContent = `${s.name} · ${s.city} · il y a ${s.days} jours`;\n    dots.forEach((d,idx)=>d.classList.toggle(\"active\", idx===i));\n    current = i;\n  }\n\n  function goTo(idx){\n    const i = Number(idx);\n    if(Number.isNaN(i)) return;\n    render(i);\n  }\n\n  dots.forEach(dot=>{\n    dot.addEventListener(\"click\",()=> goTo(dot.dataset.idx));\n    dot.addEventListener(\"keydown\",(e)=>{\n      if(e.key === \"Enter\" || e.key === \" \"){\n        e.preventDefault();\n        goTo(dot.dataset.idx);\n      }\n    });\n  });\n\n  setInterval(()=>{ render((current+1)%slides.length); }, 3500);\n  render(0);\n})();\n</script>"
          }
