        "liquid": "<style>\n  .el-compare {\n    --bg: #f6e3e7;\n    --text: #222;\n    --muted: #3a3a3a;\n    --pink: #f7c7d0;\n    --white: #ffffff;\n    --border: #111111;\n\n    background: var(--bg);\n    padding: 22px 14px 28px;\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Inter, Arial, sans-serif;\n    color: var(--text);\n  }\n\n  .el-compare * {\n    box-sizing: border-box;\n  }\n\n  .el-compare-wrap {\n    max-width: 760px;\n    margin: 0 auto;\n  }\n\n  .el-compare-title {\n    margin: 0 0 18px;\n    text-align: center;\n    font-size: 28px;\n    line-height: 1.05;\n    font-weight: 900;\n    letter-spacing: -0.8px;\n    color: #111;\n  }\n\n  .el-compare-top {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 14px;\n    align-items: start;\n    margin-bottom: 24px;\n  }\n\n  .el-compare-col {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n\n  .el-compare-photo {\n    width: 100%;\n    aspect-ratio: 1 / 1;\n    border: 3px solid var(--border);\n    border-radius: 20px;\n    overflow: hidden;\n    background: #efefef;\n  }\n\n  .el-compare-photo img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n  }\n\n  .el-compare-label {\n    margin-top: 10px;\n    font-size: 16px;\n    line-height: 1.2;\n    font-weight: 500;\n    text-align: center;\n    color: #2c2c2c;\n  }\n\n  .el-compare-select-wrap {\n    width: 100%;\n    margin-top: 10px;\n  }\n\n  .el-compare-select {\n    width: 100%;\n    height: 48px;\n    border: 3px solid var(--border);\n    border-radius: 999px;\n    background: #fff;\n    color: #111;\n    font-size: 15px;\n    font-weight: 500;\n    text-align: center;\n    text-align-last: center;\n    padding: 0 40px 0 14px;\n    outline: none;\n    appearance: none;\n    -webkit-appearance: none;\n    -moz-appearance: none;\n    background-image:\n      linear-gradient(45deg, transparent 50%, #111 50%),\n      linear-gradient(135deg