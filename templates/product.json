/div>\n  </div>\n\n</section>\n\n<style>\n.press-wrapper{\n  background:#fff;\n  padding: 30px 0 10px;\n}\n\n/* TITRE */\n.press-title{\n  text-align:center;\n  font-weight:700;\n  letter-spacing:0.18em;\n  font-size:14px;\n  color:#000;\n  margin-bottom:18px;\n}\n\n/* MARQUEE */\n.press-marquee{\n  --speed: 14s; /* PLUS RAPIDE */\n  --gap: 36px;\n\n  position: relative;\n  overflow: hidden;\n  background: #ffffff;\n  padding: 26px 0;\n}\n\n.press-marquee__track{\n  display: flex;\n  width: max-content;\n  animation: scroll var(--speed) linear infinite;\n}\n\n.press-marquee:hover .press-marquee__track{\n  animation-play-state: paused;\n}\n\n.press-marquee__group{\n  display: flex;\n  align-items: center;\n  gap: var(--gap);\n  padding: 0 var(--gap);\n}\n\n.press-marquee__group img{\n  width: 130px;\n  height: 130px;\n  object-fit: contain;\n  background: #ffffff;\n  border-radius: 18px;\n  padding: 18px;\n  box-shadow: 0 10px 26px rgba(0,0,0,.1);\n  transition: transform .25s ease, box-shadow .25s ease;\n}\n\n.press-marquee__group img:hover{\n  transform: scale(1.07);\n  box-shadow: 0 16px 38px rgba(0,0,0,.16);\n}\n\n/* FADES */\n.press-marquee__fade{\n  position:absolute;\n  top:0; bottom:0;\n  width: 120px;\n  pointer-events:none;\n  z-index:2;\n}\n.press-marquee__fade--left{\n  left:0;\n  background: linear-gradient(90deg,#fff 0%,rgba(255,255,255,0) 100%);\n}\n.press-marquee__fade--right{\n  right:0;\n  background: linear-gradient(270deg,#fff 0%,rgba(255,255,255,0) 100%);\n}\n\n@keyframes scroll{\n  from{ transform: translateX(0); }\n  to{ transform: translateX(-50%); }\n}\n</style>",
