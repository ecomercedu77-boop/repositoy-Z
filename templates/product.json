        "liquid_QzhLbe": {
          "type": "liquid",
          "settings": {
            "liquid": "<!-- ===== TIMER + STOCK MOBILE FIX ===== -->\n<p id=\"elLine\" style=\"\n  font-size:13px;\n  margin-top:6px;\n  font-weight:600;\n  display:flex;\n  flex-wrap:wrap;\n  gap:4px;\n  align-items:center;\n  line-height:1.4;\n\">\n  <span>Offre valable encore</span>\n  <span id=\"elTimer\" style=\"color:#c40000;font-weight:800;\">10:00</span>\n  <span>· Stock limité :</span>\n  <span id=\"elStock\" style=\"font-weight:800;\">4</span>\n  <span>·</span>\n  <span style=\"color:#0a8f08;font-weight:800;\">Livraison gratuite aujourd’hui</span>\n</p>\n\n<script>\n  // Timer 10 minutes\n  let time = 10 * 60;\n  const timerEl = document.getElementById(\"elTimer\");\n\n  // Stock dynamique\n  const STOCK_MIN = 3;\n  const STOCK_MAX = 7;\n  const stockEl = document.getElementById(\"elStock\");\n  let stock = Math.floor(Math.random() * (STOCK_MAX - STOCK_MIN + 1)) + STOCK_MIN;\n  stockEl.textContent = stock;\n\n  setInterval(() => {\n    time--;\n    if (time <= 0) time = 10 * 60;\n\n    const m = String(Math.floor(time / 60)).padStart(2,'0');\n    const s = String(time % 60).padStart(2,'0');\n    timerEl.textContent = `${m}:${s}`;\n  }, 1000);\n</script>\n<!-- ===== FIN ===== -->"
          }
        },
        "liquid_ANqy67": {
          "type": "liquid",
          "settings": {
            "liquid": "<style>\n:root{\n  --faq-border:#ededed;\n  --faq-text:#111;\n  --faq-muted:#555;\n  --faq-btn-bg:#f6f6f6;\n  --faq-btn-border:#e2e2e2;\n  --faq-btn-color:#777;\n}\n\n/* CONTENEUR */\n.eline-faq{\n  width:100%;\n  max-width:760px;\n  margin:0 auto;\n  font-family:inherit;\n}\n\n/* ITEM */\n.eline-faq details{\n  border-bottom:1px solid var(--faq-border);\n}\n\n/* QUESTION */\n.eline-faq summary{\n  list-style:none;\n  cursor:pointer;\n  display:flex;\n  align-items:center;\n  justify-content:space-between;\n  gap:12px;\n  padding:16px 0;\n  font-size:16px;\n  font-weight:600;\n  color:var(--faq-text);\n}\n.eline-faq summary::-webkit-details-marker{ display:none; }\n\n.faq-q{ flex:1; }\n\n/* BOUTON + / - */\n.faq-btn{\n  width:30px;\n  height:30px;\n  border-radius:50%;\n  background:var(--faq-btn-bg);\n  border:1px solid var(--faq-btn-border);\n  color:var(--faq-btn-color);\n  display:flex;\n  align-items:center;\n  justify-content:center;\n  font-size:18px;\n}\n\n/* OUVERT = - */\ndetails[open] .faq-btn{ color:#444; }\n\n/* CONTENU */\n.eline-content{\n  padding:0 0 14px;\n  font-size:14px;\n  line-height:1.65;\n  color:var(--faq-muted);\n}\n.eline-content p{ margin:0 0 10px; }\n.eline-content ul{ margin:0 0 10px 18px; }\n.eline-content li{ margin-bottom:6px; }\n.eline-content strong{ color:var(--faq-text); }\n\n/* Mobile */\n@media(max-width:480px){\n  .eline-faq summary{ font-size:15px; padding:14px 0; }\n}\n</style>\n\n<div class=\"eline-faq\" id=\"elineFaq\">\n\n  <details>\n    <summary>\n      <span class=\"faq-q\">Qu’est-ce que ELINEA ?</span>\n      <span class=\"faq-btn\">+</span>\n    </summary>\n    <div class=\"eline-content\">\n      <p><strong>ELINEA</strong> est une solution beauté 2-en-1 conçue pour simplifier votre routine.</p>\n      <p>Double tête, utilisation douce et précise, idéale pour les peaux sensibles.</p>\n      <p>Étanche et rechargeable en USB-C, elle s’utilise sur peau sèche ou humide.</p>\n    </div>\n  </details>\n\n  <details>\n    <summary>\n      <span class=\"faq-q\">Que contient le pack ELINEA ?</span>\n      <span class=\"faq-btn\">+</span>\n    </summary>\n    <div class=\"eline-content\">\n      <ul>\n        <li>Tête de tonte corps</li>\n        <li>Tête de précision</li>\n        <li>Sabot</li>\n        <li>Câble de chargement USB-C</li>\n        <li>Brosse de nettoyage</li>\n        <li>Manuel d’utilisation</li>\n        <li><strong>E-book offert</strong></li>\n      </ul>\n    </div>\n  </details>\n\n  <details>\n    <summary>\n      <span class=\"faq-q\">Conseils d’utilisation</span>\n      <span class=\"faq-btn\">+</span>\n    </summary>\n    <div class=\"eline-content\">\n      <p><strong>Avant :</strong> exfolier la peau 24h avant.</p>\n      <p><strong>Pendant :</strong> angle ~30°, pression légère.</p>\n      <p><strong>Après :</strong> soin apaisant sans alcool.</p>\n    </div>\n  </details>\n\n  <details>\n    <summary>\n      <span class=\"faq-q\">Expédition</span>\n      <span class=\"faq-btn\">+</span>\n    </summary>\n    <div class=\"eline-content\">\n      <p>\n        Commande passée aujourd’hui (<strong><span data-today></span></strong>)\n        avant <strong>minuit</strong> : expédition <strong>le jour même</strong>.\n      </p>\n    </div>\n  </details>\n\n  <details>\n    <summary>\n      <span class=\"faq-q\">Garantie 30 jours Satisfait ou Remboursé</span>\n      <span class=\"faq-btn\">+</span>\n    </summary>\n    <div class=\"eline-content\">\n      <p>Essayez ELINEA pendant 30 jours.</p>\n      <p>Remboursement intégral si vous n’êtes pas satisfait.</p>\n    </div>\n  </details>\n\n</div>\n\n<script>\n(() => {\n  const items = document.querySelectorAll('#elineFaq details');\n\n  items.forEach(d => {\n    const btn = d.querySelector('.faq-btn');\n\n    d.addEventListener('toggle', () => {\n      items.forEach(o => {\n        const b = o.querySelector('.faq-btn');\n        if(o === d && o.open){\n          b.textContent = '−';\n        } else {\n          o.removeAttribute('open');\n          b.textContent = '+';\n        }\n      });\n    });\n  });\n\n  const today = new Date();\n  const fmt = today.toLocaleDateString('fr-FR', {\n    weekday:'long',\n    year:'numeric',\n    month:'long',\n    day:'numeric'\n  });\n\n  document.querySelectorAll('[data-today]')\n    .forEach(el => el.textContent = fmt);\n})();\n</script>"
          }
        }
