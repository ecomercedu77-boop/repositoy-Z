          "settings": {
            "liquid": "<!-- ===== TIMER + STOCK MOBILE FIX ===== -->\n<p id=\"elLine\" style=\"\n  font-size:13px;\n  margin-top:6px;\n  font-weight:600;\n  display:flex;\n  flex-wrap:wrap;\n  gap:4px;\n  align-items:center;\n  line-height:1.4;\n\">\n  <span>Offre valable encore</span>\n  <span id=\"elTimer\" style=\"color:#c40000;font-weight:800;\">10:00</span>\n  <span>· Stock limité :</span>\n  <span id=\"elStock\" style=\"font-weight:800;\">4</span>\n  <span>·</span>\n  <span style=\"color:#0a8f08;font-weight:800;\">Livraison gratuite aujourd’hui</span>\n</p>\n\n<script>\n  // Timer 10 minutes\n  let time = 10 * 60;\n  const timerEl = document.getElementById(\"elTimer\");\n\n  // Stock dynamique\n  const STOCK_MIN = 3;\n  const STOCK_MAX = 7;\n  const stockEl = document.getElementById(\"elStock\");\n  let stock = Math.floor(Math.random() * (STOCK_MAX - STOCK_MIN + 1)) + STOCK_MIN;\n  stockEl.textContent = stock;\n\n  setInterval(() => {\n    time--;\n    if (time <= 0) time = 10 * 60;\n\n    const m = String(Math.floor(time / 60)).padStart(2,'0');\n    const s = String(time % 60).padStart(2,'0');\n    timerEl.textContent = `${m}:${s}`;\n  }, 1000);\n</script>\n<!-- ===== FIN ===== -->"
          }
        },
        "liquid_ANqy67": {
