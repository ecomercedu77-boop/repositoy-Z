        "liquid": "<style>\n  .reviews-proof {\n    background: #ffffff;\n    border-radius: 20px;\n    padding: 24px;\n    max-width: 1100px;\n    margin: 0 auto;\n    border: 1px solid rgba(0,0,0,.06);\n    box-shadow: 0 12px 32px rgba(0,0,0,.08);\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Inter, Arial, sans-serif;\n  }\n\n  .rp-title {\n    font-size: 26px;\n    font-weight: 800;\n    color: #111;\n    margin-bottom: 8px;\n  }\n\n  .rp-meta {\n    display: flex;\n    flex-wrap: wrap;\n    align-items: center;\n    gap: 12px;\n    font-size: 14px;\n    color: #444;\n    margin-bottom: 20px;\n  }\n\n  .rp-stars svg { width: 16px; height: 16px; fill: #00b67a; }\n\n  .rp-grid{\n    display:grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap:16px;\n  }\n\n  .rp-card{\n    background:#fafafa;\n    border-radius:16px;\n    padding:10px;\n    border:1px solid rgba(0,0,0,.06);\n    display:flex;\n    flex-direction:column;\n    gap:10px;\n  }\n\n  .rp-imgwrap{\n    width:100%;\n    aspect-ratio: 4 / 5;\n    border-radius:12px;\n    background:#f3f4f6;\n    overflow:hidden;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n  }\n\n  .rp-card img{\n    width:100%;\n    height:100%;\n    object-fit:contain;\n    display:block;\n  }\n\n  .rp-name{\n    font-size:14px;\n    font-weight:800;\n    color:#111;\n    margin-top:2px;\n  }\n\n  .rp-comment{\n    font-size:13px;\n    color:#333;\n    line-height:1.45;\n  }\n\n  @media (max-width: 900px){\n    .rp-grid{ grid-template-columns: repeat(2, 1fr); }\n  }\n\n  @media (max-width: 600px){\n    .reviews-proof{ padding:16px; }\n    .rp-title{ font-size:22px; }\n\n    .rp-grid{\n      display:flex;\n      gap:12px;\n      overflow-x:auto;\n      scroll-snap-type: x mandatory;\n      -webkit-overflow-scrolling: touch;\n      padding-bottom:6px;\n    }\n\n    .rp-grid::-webkit-scrollbar{display:none}\n\n    .rp-card{\n      flex: 0 0 86%;\n      scroll-snap-align: center;\n      padding:12px;\n      border-radius:18px;\n    }\n\n    .rp-imgwrap{\n      aspect-ratio: 9 / 16;\n      border-radius:14px;\n    }\n\n    .rp-name{ font-size:15px; }\n    .rp-comment{ font-size:14px; }\n  }\n</style>\n\n<section class=\"reviews-proof\">\n  <h2 class=\"rp-title\">Nos clients recommandent ELINEA</h2>\n\n  <div class=\"rp-meta\">\n    <strong>Excellent • 4.7 / 5</strong>\n\n    <span class=\"rp-stars\">\n      <svg viewBox=\"0 0 24 24\"><path d=\"M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z\"/></svg>\n      <svg viewBox=\"0 0 24 24\"><path d=\"M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z\"/></svg>\n      <svg viewBox=\"0 0 24 24\"><path d=\"M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z\"/></svg>\n      <svg viewBox=\"0 0 24 24\"><path d=\"M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z\"/></svg>\n      <svg viewBox=\"0 0 24 24\"><path d=\"M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z\"/></svg>\n    </span>\n\n    <span>basé sur +1800 avis</span>\n  </div>\n\n  <div class=\"rp-grid\">\n\n    <div class=\"rp-card\">\n      <div class=\"rp-imgwrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/ARYA_LUSH_AV_AP.webp?v=1768083523\">\n      </div>\n      <div class=\"rp-name\">Lucas D.</div>\n      <div class=\"rp-comment\">« Avant j’avais toujours des rougeurs dans le cou après le rasage. Avec ça c’est beaucoup plus propre et surtout aucune brûlure. »</div>\n    </div>\n\n    <div class=\"rp-card\">\n      <div class=\"rp-imgwrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/ARYA_LUSH_AV_AP_2.webp?v=1768083523\">\n      </div>\n      <div class=\"rp-name\">Maxime M.</div>\n      <div class=\"rp-comment\">« J’ai la peau sensible et les rasoirs classiques m’irritaient. Là la barbe est nette et la peau reste confortable. »</div>\n    </div>\n\n    <div class=\"rp-card\">\n      <div class=\"rp-imgwrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/ARYA_LUSH_AV_AP_3.webp?v=1768083523\">\n      </div>\n      <div class=\"rp-name\">Thomas R.</div>\n      <div class=\"rp-comment\">« Je voulais un truc simple pour entretenir ma barbe. Pas de coupures et le résultat est vraiment propre. »</div>\n    </div>\n\n    <div class=\"rp-card\">\n      <div class=\"rp-imgwrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/29481dcd-4149-47cc-9022-7bb36afa6fff.png?v=1769957293\">\n      </div>\n      <div class=\"rp-name\">Nicolas B.</div>\n      <div class=\"rp-comment\">« J’avais souvent des petits boutons après le rasage. Depuis que je l’utilise ma peau est beaucoup plus nette. »</div>\n    </div>\n\n    <div class=\"rp-card\">\n      <div class=\"rp-imgwrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/d115ed03-2b4a-4324-888b-59024a9c511c.png?v=1769957294\">\n      </div>\n      <div class=\"rp-name\">Julien T.</div>\n      <div class=\"rp-comment\">« Parfait pour entretenir la barbe rapidement. Je peux le faire à la maison en quelques minutes. »</div>\n    </div>\n\n    <div class=\"rp-card\">\n      <div class=\"rp-imgwrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/ce215593-e0b6-4ffb-9da8-96023f8e471b.png?v=1769957293\">\n      </div>\n      <div class=\"rp-name\">Alexandre P.</div>\n      <div class=\"rp-comment\">« Je l’utilise pour la barbe et le cou. Le résultat est propre et la peau reste douce. »</div>\n    </div>\n\n    <div class=\"rp-card\">\n      <div class=\"rp-imgwrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/d61cfe72-827c-4774-ba96-436e61328b36.png?v=1769957292\">\n      </div>\n      <div class=\"rp-name\">Kevin L.</div>\n      <div class=\"rp-comment\">« Beaucoup plus pratique qu’un rasoir classique. Pas d’irritations et ça va beaucoup plus vite. »</div>\n    </div>\n\n    <div class=\"rp-card\">\n      <div class=\"rp-imgwrap\">\n        <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/b5a87788-006f-4535-9ce3-306b43da27c6.png?v=1769957295\">\n      </div>\n      <div class=\"rp-name\">Anthony G.</div>\n      <div class=\"rp-comment\">« Franchement surpris du résultat. La barbe est nette et je n’ai plus les irritations des rasoirs jetables. »</div>\n    </div>\n\n  </div>\n</section>",
