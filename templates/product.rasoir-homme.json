        "liquid": "<style>\n  .reviews-proof {\n    background: #ffffff;\n    border-radius: 18px;\n    padding: 16px;\n    max-width: 1100px;\n    margin: 0 auto;\n    border: 1px solid rgba(0,0,0,.06);\n    box-shadow: 0 10px 26px rgba(0,0,0,.06);\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Inter, Arial, sans-serif;\n    overflow: hidden;\n  }\n\n  .rp-head {\n    margin-bottom: 14px;\n  }\n\n  .rp-title {\n    font-size: 22px;\n    line-height: 1.15;\n    font-weight: 800;\n    color: #111;\n    margin: 0 0 8px;\n    letter-spacing: -0.3px;\n  }\n\n  .rp-meta {\n    display: flex;\n    flex-wrap: wrap;\n    align-items: center;\n    gap: 8px;\n    font-size: 13px;\n    color: #444;\n  }\n\n  .rp-meta strong {\n    color: #111;\n  }\n\n  .rp-stars {\n    display: inline-flex;\n    align-items: center;\n    gap: 2px;\n  }\n\n  .rp-stars svg {\n    width: 14px;\n    height: 14px;\n    fill: #00b67a;\n    flex: 0 0 auto;\n  }\n\n  .rp-slider-wrap {\n    position: relative;\n  }\n\n  .rp-grid {\n    display: flex;\n    gap: 12px;\n    overflow-x: auto;\n    scroll-snap-type: x mandatory;\n    scroll-behavior: smooth;\n    -webkit-overflow-scrolling: touch;\n    padding-bottom: 4px;\n  }\n\n  .rp-grid::-webkit-scrollbar {\n    display: none;\n  }\n\n  .rp-card {\n    flex: 0 0 84%;\n    background: #fafafa;\n    border-radius: 16px;\n    padding: 10px;\n    border: 1px solid rgba(0,0,0,.06);\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n    scroll-snap-align: center;\n  }\n\n  .rp-imgwrap {\n    width: 100%;\n    aspect-ratio: 4 / 5;\n    border-radius: 12px;\n    background: #f3f4f6;\n    overflow: hidden;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .rp-card img {\n    width: 100%;\n    height: 100%;\n    object-fit: contain;\n    display: block;\n    background: #f3f4f6;\n  }\n\n  .rp-content {\n    padding: 2px 2px 4px;\n  }\n\n  .rp-name {\n    font-size: 15px;\n    font-weight: 800;\n    color: #111;\n    margin-bottom: 6px;\n    line-height: 1.2;\n  }\n\n  .rp-comment {\n    font-size: 14px;\n    color: #333;\n    line-height: 1.5;\n  }\n\n  .rp-controls {\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    gap: 10px;\n    margin-top: 14px;\n  }\n\n  .rp-btn {\n    width: 42px;\n    height: 42px;\n    border-radius: 999px;\n    border: 1px solid rgba(0,0,0,.1);\n    background: #fff;\n    color: #111;\n    font-size: 18px;\n    cursor: pointer;\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    box-shadow: 0 4px 12px rgba(0,0,0,.05);\n  }\n\n  .rp-btn:active {\n    transform: scale(0.98);\n  }\n\n  .rp-dots {\n    display: flex;\n    align-items: center;\n    gap: 6px;\n  }\n\n  .rp-dot {\n    width: 7px;\n    height: 7px;\n    border-radius: 50%;\n    background: rgba(0,0,0,.18);\n    transition: all .2s ease;\n  }\n\n  .rp-dot.active {\n    background: #111;\n    transform: scale(1.15);\n  }\n\n  @media (min-width: 768px) {\n    .reviews-proof {\n      padding: 22px;\n      border-radius: 20px;\n    }\n\n    .rp-title {\n      font-size: 26px;\n    }\n\n    .rp-grid {\n      display: grid;\n      grid-template-columns: repeat(3, 1fr);\n      gap: 16px;\n      overflow: visible;\n    }\n\n    .rp-card {\n      flex: auto;\n    }\n\n    .rp-controls {\n      display: none;\n    }\n  }\n\n  @media (min-width: 1100px) {\n    .rp-grid {\n      grid-template-columns: repeat(4, 1fr);\n    }\n  }\n</style>\n\n<section class=\"reviews-proof\">\n  <div class=\"rp-head\">\n    <h2 class=\"rp-title\">+1800 clients recommandent ELINEA</h2>\n\n    <div class=\"rp-meta\">\n      <strong>Excellent • 4.8 / 5</strong>\n\n      <span class=\"rp-stars\" aria-hidden=\"true\">\n        <svg viewBox=\"0 0 24 24\"><path d=\"M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z\"/></svg>\n        <svg viewBox=\"0 0 24 24\"><path d=\"M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z\"/></svg>\n        <svg viewBox=\"0 0 24 24\"><path d=\"M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z\"/></svg>\n        <svg viewBox=\"0 0 24 24\"><path d=\"M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z\"/></svg>\n        <svg viewBox=\"0 0 24 24\"><path d=\"M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z\"/></svg>\n      </span>\n\n      <span>basé sur +1800 avis</span>\n    </div>\n  </div>\n\n  <div class=\"rp-slider-wrap\">\n    <div class=\"rp-grid\" id=\"rpGrid\">\n\n      <div class=\"rp-card\">\n        <div class=\"rp-imgwrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/ARYA_LUSH_AV_AP.webp?v=1768083523\" alt=\"Avis client Elinea 1\">\n        </div>\n        <div class=\"rp-content\">\n          <div class=\"rp-name\">Thomas L.</div>\n          <div class=\"rp-comment\">« Après quelques séances, j’ai déjà vu une vraie différence sur le torse et le ventre. »</div>\n        </div>\n      </div>\n\n      <div class=\"rp-card\">\n        <div class=\"rp-imgwrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/ARYA_LUSH_AV_AP_2.webp?v=1768083523\" alt=\"Avis client Elinea 2\">\n        </div>\n        <div class=\"rp-content\">\n          <div class=\"rp-name\">Lucas M.</div>\n          <div class=\"rp-comment\">« Le mode glacé est super confortable, même sur les zones les plus sensibles. »</div>\n        </div>\n      </div>\n\n      <div class=\"rp-card\">\n        <div class=\"rp-imgwrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/ARYA_LUSH_AV_AP_3.webp?v=1768083523\" alt=\"Avis client Elinea 3\">\n        </div>\n        <div class=\"rp-content\">\n          <div class=\"rp-name\">Nicolas R.</div>\n          <div class=\"rp-comment\">« Franchement pratique, je fais tout à la maison sans perdre de temps. »</div>\n        </div>\n      </div>\n\n      <div class=\"rp-card\">\n        <div class=\"rp-imgwrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/29481dcd-4149-47cc-9022-7bb36afa6fff.png?v=1769957293\" alt=\"Avis client Elinea 4\">\n        </div>\n        <div class=\"rp-content\">\n          <div class=\"rp-name\">Mehdi B.</div>\n          <div class=\"rp-comment\">« Résultats visibles en quelques semaines sur le dos et les épaules. »</div>\n        </div>\n      </div>\n\n      <div class=\"rp-card\">\n        <div class=\"rp-imgwrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/d115ed03-2b4a-4324-888b-59024a9c511c.png?v=1769957294\" alt=\"Avis client Elinea 5\">\n        </div>\n        <div class=\"rp-content\">\n          <div class=\"rp-name\">Yanis T.</div>\n          <div class=\"rp-comment\">« Très simple à utiliser et les résultats arrivent plus vite que je pensais. »</div>\n        </div>\n      </div>\n\n      <div class=\"rp-card\">\n        <div class=\"rp-imgwrap\">\n          <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/ce215593-e0b6-4ffb-9da8-96023f8e471b.png?v=1769957293\" alt=\"Avis client Elinea 6\">\n        </div>\n        <div class=\"rp-content\">\n          <div class=\"rp-name\">Karim P.</div>\n          <div class=\"rp-comment\">« Ma peau est plus propre, plus nette, et j’ai beaucoup moins d’irritations après rasage. »</div>\n        </div>\n      </div>\n\n    </div>\n\n    <div class=\"rp-controls\">\n      <button class=\"rp-btn\" id=\"rpPrev\" aria-label=\"Image précédente\">‹</button>\n      <div class=\"rp-dots\" id=\"rpDots\"></div>\n      <button class=\"rp-btn\" id=\"rpNext\" aria-label=\"Image suivante\">›</button>\n    </div>\n  </div>\n</section>\n\n<script>\n(function () {\n  const grid = document.getElementById('rpGrid');\n  const prevBtn = document.getElementById('rpPrev');\n  const nextBtn = document.getElementById('rpNext');\n  const dotsWrap = document.getElementById('rpDots');\n\n  if (!grid || !prevBtn || !nextBtn || !dotsWrap) return;\n\n  const cards = Array.from(grid.querySelectorAll('.rp-card'));\n  if (!cards.length) return;\n\n  cards.forEach((_, index) => {\n    const dot = document.createElement('span');\n    dot.className = 'rp-dot' + (index === 0 ? ' active' : '');\n    dot.dataset.index = index;\n    dotsWrap.appendChild(dot);\n  });\n\n  const dots = Array.from(dotsWrap.querySelectorAll('.rp-dot'));\n\n  function getCardStep() {\n    if (!cards[0]) return 0;\n    const cardWidth = cards[0].getBoundingClientRect().width;\n    const styles = window.getComputedStyle(grid);\n    const gap = parseFloat(styles.columnGap || styles.gap || 12);\n    return cardWidth + gap;\n  }\n\n  function getCurrentIndex() {\n    const step = getCardStep();\n    if (!step) return 0;\n    return Math.round(grid.scrollLeft / step);\n  }\n\n  function updateDots() {\n    const index = Math.max(0, Math.min(cards.length - 1, getCurrentIndex()));\n    dots.forEach((dot, i) => {\n      dot.classList.toggle('active', i === index);\n    });\n  }\n\n  function goToIndex(index) {\n    const safeIndex = Math.max(0, Math.min(cards.length - 1, index));\n    const step = getCardStep();\n    grid.scrollTo({\n      left: safeIndex * step,\n      behavior: 'smooth'\n    });\n    setTimeout(updateDots, 250);\n  }\n\n  prevBtn.addEventListener('click', () => {\n    goToIndex(getCurrentIndex() - 1);\n  });\n\n  nextBtn.addEventListener('click', () => {\n    goToIndex(getCurrentIndex() + 1);\n  });\n\n  dots.forEach(dot => {\n    dot.addEventListener('click', () => {\n      goToIndex(Number(dot.dataset.index));\n    });\n  });\n\n  grid.addEventListener('scroll', () => {\n    window.requestAnimationFrame(updateDots);\n  });\n\n  window.addEventListener('resize', updateDots);\n\n  updateDots();\n})();\n</script>",
