        "remove_horizontal_spacing": false,
        "liquid": "<style>\n.eline-steps {\n  background: #f4ecee;\n  padding: 18px 10px 30px;\n  font-family: -apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Arial,sans-serif;\n  position: relative;\n}\n\n.eline-steps-title {\n  text-align: center;\n  font-size: 28px;\n  font-weight: 500;\n  margin-bottom: 16px;\n}\n\n/* SCROLL */\n.eline-steps-scroll {\n  display: flex;\n  gap: 14px;\n  overflow-x: auto;\n  scroll-snap-type: x mandatory;\n  -webkit-overflow-scrolling: touch;\n  padding: 6px;\n}\n\n.eline-steps-scroll::-webkit-scrollbar {display:none;}\n\n.eline-step-card {\n  flex: 0 0 90%;\n  scroll-snap-align: center;\n}\n\n/* IMAGE */\n.eline-step-media {\n  position: relative;\n  border: 3px solid #111;\n  border-radius: 26px;\n  overflow: visible;\n  background: #fff;\n}\n\n.eline-step-media img {\n  width: 100%;\n  border-radius: 22px;\n  aspect-ratio: 4/5;\n  object-fit: cover;\n}\n\n/* NUMERO */\n.eline-step-badge {\n  position: absolute;\n  top: -18px;\n  left: 50%;\n  transform: translateX(-50%);\n  width: 64px;\n  height: 64px;\n  border-radius: 50%;\n  background: #000;\n  color: #fff;\n  font-size: 26px;\n  display: flex;\n  align-items: center;\n  justify-content: center;\n}\n\n/* TEXTE */\n.eline-step-text {\n  text-align: center;\n  padding: 14px 10px 0;\n}\n\n.eline-step-text h3 {\n  font-size: 18px;\n  font-weight: 800;\n  margin-bottom: 6px;\n}\n\n.eline-step-text p {\n  font-size: 15px;\n  color: #222;\n}\n\n/* DOTS */\n.eline-dots {\n  display: flex;\n  justify-content: center;\n  gap: 8px;\n  margin-top: 16px;\n}\n\n.eline-dot {\n  width: 7px;\n  height: 7px;\n  border-radius: 50%;\n  background: rgba(0,0,0,.2);\n}\n\n.eline-dot.active {\n  background: #000;\n}\n\n/* FLÈCHES */\n.eline-arrow {\n  position: absolute;\n  top: 55%;\n  transform: translateY(-50%);\n  width: 38px;\n  height: 38px;\n  border-radius: 50%;\n  background: #fff;\n  border: 1px solid rgba(0,0,0,.1);\n  display: flex;\n  align-items: center;\n  justify-content: center;\n  font-size: 18px;\n  cursor: pointer;\n  z-index: 5;\n}\n\n.eline-arrow.left { left: 4px; }\n.eline-arrow.right { right: 4px; }\n\n@media(max-width:640px){\n  .eline-arrow{\n    width:34px;\n    height:34px;\n    font-size:16px;\n  }\n}\n</style>\n\n<section class=\"eline-steps\">\n\n  <h2 class=\"eline-steps-title\">Comment ça marche ?</h2>\n\n  <!-- FLÈCHES -->\n  <div class=\"eline-arrow left\" id=\"elinePrev\">‹</div>\n  <div class=\"eline-arrow right\" id=\"elineNext\">›</div>\n\n  <div class=\"eline-steps-scroll\" id=\"elineScroll\">\n\n    <!-- 1 -->\n    <div class=\"eline-step-card\">\n      <div class=\"eline-step-media\">\n        <div class=\"eline-step-badge\">1</div>\n        <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/1.png?v=1774912134\">\n      </div>\n      <div class=\"eline-step-text\">\n        <h3>Exfoliez la peau</h3>\n        <p>Prépare la peau et réduit les poils incarnés</p>\n      </div>\n    </div>\n\n    <!-- 2 -->\n    <div class=\"eline-step-card\">\n      <div class=\"eline-step-media\">\n        <div class=\"eline-step-badge\">2</div>\n        <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/2.png?v=1774912134\">\n      </div>\n      <div class=\"eline-step-text\">\n        <h3>Rasez la zone</h3>\n        <p>Le poil doit être coupé pour cibler la racine</p>\n      </div>\n    </div>\n\n    <!-- 3 -->\n    <div class=\"eline-step-card\">\n      <div class=\"eline-step-media\">\n        <div class=\"eline-step-badge\">3</div>\n        <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/3.png?v=1774912134\">\n      </div>\n      <div class=\"eline-step-text\">\n        <h3>Utilisez l’IPL</h3>\n        <p>Réduit la repousse durablement</p>\n      </div>\n    </div>\n\n    <!-- 4 -->\n    <div class=\"eline-step-card\">\n      <div class=\"eline-step-media\">\n        <div class=\"eline-step-badge\">4</div>\n        <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/4.png?v=1774912134\">\n      </div>\n      <div class=\"eline-step-text\">\n        <h3>Hydratez</h3>\n        <p>Apaise et protège la peau</p>\n      </div>\n    </div>\n\n    <!-- 5 -->\n    <div class=\"eline-step-card\">\n      <div class=\"eline-step-media\">\n        <div class=\"eline-step-badge\">5</div>\n        <img src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/5.png?v=1774912134\">\n      </div>\n      <div class=\"eline-step-text\">\n        <h3>Résultat</h3>\n        <p>Peau douce et lisse</p>\n      </div>\n    </div>\n\n  </div>\n\n  <div class=\"eline-dots\" id=\"elineDots\"></div>\n\n</section>\n\n<script>\nconst track = document.getElementById(\"elineScroll\");\nconst cards = track.querySelectorAll(\".eline-step-card\");\nconst dotsWrap = document.getElementById(\"elineDots\");\nconst prev = document.getElementById(\"elinePrev\");\nconst next = document.getElementById(\"elineNext\");\n\nlet index = 0;\n\n/* DOTS */\ncards.forEach((_, i)=>{\n  const d = document.createElement(\"div\");\n  d.className = \"eline-dot\" + (i===0 ? \" active\":\"\");\n  dotsWrap.appendChild(d);\n});\n\nconst dots = dotsWrap.querySelectorAll(\".eline-dot\");\n\nfunction update(){\n  dots.forEach((d,i)=> d.classList.toggle(\"active\", i===index));\n}\n\nfunction scrollToIndex(i){\n  const cardWidth = cards[0].offsetWidth + 14;\n  track.scrollTo({\n    left: i * cardWidth,\n    behavior: \"smooth\"\n  });\n  index = i;\n  update();\n}\n\n/* ARROWS */\nnext.onclick = ()=> {\n  index = Math.min(cards.length-1, index+1);\n  scrollToIndex(index);\n};\n\nprev.onclick = ()=> {\n  index = Math.max(0, index-1);\n  scrollToIndex(index);\n};\n</script>",
