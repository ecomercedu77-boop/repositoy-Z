        "liquid": "<style>\n  .el-compare {\n    --bg: #f6e3e7;\n    --text: #222;\n    --muted: #3a3a3a;\n    --pink: #f7c7d0;\n    --white: #ffffff;\n    --border: #111111;\n\n    background: var(--bg);\n    padding: 22px 14px 28px;\n    font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Inter, Arial, sans-serif;\n    color: var(--text);\n  }\n\n  .el-compare * {\n    box-sizing: border-box;\n  }\n\n  .el-compare-wrap {\n    max-width: 760px;\n    margin: 0 auto;\n  }\n\n  .el-compare-title {\n    margin: 0 0 18px;\n    text-align: center;\n    font-size: 28px;\n    line-height: 1.05;\n    font-weight: 900;\n    letter-spacing: -0.8px;\n    color: #111;\n  }\n\n  .el-compare-top {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    gap: 14px;\n    align-items: start;\n    margin-bottom: 24px;\n  }\n\n  .el-compare-col {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n  }\n\n  .el-compare-photo {\n    width: 100%;\n    aspect-ratio: 1 / 1;\n    border: 3px solid var(--border);\n    border-radius: 20px;\n    overflow: hidden;\n    background: #efefef;\n  }\n\n  .el-compare-photo img {\n    width: 100%;\n    height: 100%;\n    object-fit: cover;\n    display: block;\n  }\n\n  .el-compare-label {\n    margin-top: 10px;\n    font-size: 16px;\n    line-height: 1.2;\n    font-weight: 500;\n    text-align: center;\n    color: #2c2c2c;\n  }\n\n  .el-compare-select-wrap {\n    width: 100%;\n    margin-top: 10px;\n  }\n\n  .el-compare-select {\n    width: 100%;\n    height: 48px;\n    border: 3px solid var(--border);\n    border-radius: 999px;\n    background: #fff;\n    color: #111;\n    font-size: 15px;\n    font-weight: 500;\n    text-align: center;\n    text-align-last: center;\n    padding: 0 40px 0 14px;\n    outline: none;\n    appearance: none;\n    -webkit-appearance: none;\n    -moz-appearance: none;\n    background-image:\n      linear-gradient(45deg, transparent 50%, #111 50%),\n      linear-gradient(135deg, #111 50%, transparent 50%);\n    background-position:\n      calc(100% - 22px) 20px,\n      calc(100% - 15px) 20px;\n    background-size: 7px 7px, 7px 7px;\n    background-repeat: no-repeat;\n  }\n\n  .el-compare-grid {\n    display: grid;\n    grid-template-columns: 1fr 1fr;\n    column-gap: 16px;\n    row-gap: 28px;\n  }\n\n  .el-compare-item {\n    text-align: center;\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    min-height: 120px;\n  }\n\n  .el-compare-icon {\n    width: 62px;\n    height: 62px;\n    border-radius: 50%;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    margin-bottom: 12px;\n    font-size: 32px;\n    line-height: 1;\n    font-weight: 500;\n  }\n\n  .el-compare-icon.ok {\n    background: var(--pink);\n    color: #111;\n  }\n\n  .el-compare-icon.no {\n    background: rgba(255,255,255,.8);\n    color: #111;\n  }\n\n  .el-compare-text {\n    font-size: 16px;\n    line-height: 1.42;\n    color: var(--muted);\n    max-width: 170px;\n    margin: 0 auto;\n  }\n\n  .el-compare-text strong {\n    font-weight: 800;\n    color: #222;\n  }\n\n  @media (min-width: 641px) {\n    .el-compare {\n      padding: 28px 20px 34px;\n    }\n\n    .el-compare-title {\n      font-size: 42px;\n      margin-bottom: 28px;\n    }\n\n    .el-compare-top {\n      gap: 22px;\n      margin-bottom: 30px;\n    }\n\n    .el-compare-photo {\n      border-width: 4px;\n      border-radius: 26px;\n    }\n\n    .el-compare-label {\n      font-size: 22px;\n      margin-top: 14px;\n    }\n\n    .el-compare-select {\n      height: 58px;\n      font-size: 18px;\n      border-width: 4px;\n      background-position:\n        calc(100% - 26px) 24px,\n        calc(100% - 18px) 24px;\n      background-size: 8px 8px, 8px 8px;\n    }\n\n    .el-compare-grid {\n      column-gap: 34px;\n      row-gap: 34px;\n    }\n\n    .el-compare-item {\n      min-height: 150px;\n    }\n\n    .el-compare-icon {\n      width: 84px;\n      height: 84px;\n      font-size: 42px;\n      margin-bottom: 16px;\n    }\n\n    .el-compare-text {\n      font-size: 22px;\n      max-width: 320px;\n      line-height: 1.38;\n    }\n  }\n</style>\n\n<section class=\"el-compare\">\n  <div class=\"el-compare-wrap\">\n    <h2 class=\"el-compare-title\">Elinea comparé à...</h2>\n\n    <div class=\"el-compare-top\">\n      <div class=\"el-compare-col\">\n        <div class=\"el-compare-photo\">\n          <img\n            src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/63ebf8c5-179a-42dd-8ddf-0d1460c83b37.png?v=1774898502\"\n            alt=\"IPL Elinea\"\n          >\n        </div>\n        <div class=\"el-compare-label\">IPL Elinea</div>\n      </div>\n\n      <div class=\"el-compare-col\">\n        <div class=\"el-compare-photo\">\n          <img\n            id=\"elCompareImage\"\n            src=\"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/IMG_3974.jpg?v=1774904615\"\n            alt=\"Rasoir\"\n          >\n        </div>\n\n        <div class=\"el-compare-select-wrap\">\n          <select id=\"elCompareSelect\" class=\"el-compare-select\" aria-label=\"Choisir une comparaison\">\n            <option value=\"rasoir\">Rasoir</option>\n            <option value=\"cire\">Épilation à la cire</option>\n            <option value=\"clinique\">Laser clinique</option>\n          </select>\n        </div>\n      </div>\n    </div>\n\n    <div class=\"el-compare-grid\" id=\"elCompareGrid\"></div>\n  </div>\n</section>\n\n<script>\n  (function () {\n    const compareImage = document.getElementById(\"elCompareImage\");\n    const compareSelect = document.getElementById(\"elCompareSelect\");\n    const compareGrid = document.getElementById(\"elCompareGrid\");\n\n    const comparisons = {\n      rasoir: {\n        image: \"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/IMG_3974.jpg?v=1774904615\",\n        alt: \"Rasoir\",\n        rows: [\n          {\n            left: \"Sans <strong>douleur</strong> et sans irritation\",\n            right: \"<strong>Poils incarnés</strong>, irritations et coupures\"\n          },\n          {\n            left: \"Élimine les poils à la <strong>racine</strong>\",\n            right: \"<strong>Résultat temporaire</strong> et repousse rapide\"\n          },\n          {\n            left: \"<strong>Moins cher</strong> sur le long terme\",\n            right: \"Dépense <strong>répétitive</strong> à vie\"\n          }\n        ]\n      },\n      cire: {\n        image: \"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/IMG_3971.jpg?v=1774904618\",\n        alt: \"Épilation à la cire\",\n        rows: [\n          {\n            left: \"Totalement <strong>sans douleur</strong>\",\n            right: \"La cire <strong>arrache</strong> les poils\"\n          },\n          {\n            left: \"<strong>Intimité</strong> totale à domicile\",\n            right: \"Souvent en institut ou manipulation compliquée\"\n          },\n          {\n            left: \"Simple, <strong>rapide</strong> et pratique\",\n            right: \"Processus long et <strong>contraignant</strong>\"\n          }\n        ]\n      },\n      clinique: {\n        image: \"https://cdn.shopify.com/s/files/1/1003/8496/4940/files/IMG_3973.jpg?v=1774904619\",\n        alt: \"Laser clinique\",\n        rows: [\n          {\n            left: \"Traitement en <strong>12 utilisations</strong>\",\n            right: \"Séances sur <strong>plusieurs mois</strong>\"\n          },\n          {\n            left: \"<strong>Paiement unique</strong>, plus économique\",\n            right: \"Traitement <strong>très coûteux</strong>\"\n          },\n          {\n            left: \"Utilisation à <strong>domicile</strong>\",\n            right: \"Rendez-vous et contraintes de <strong>clinique</strong>\"\n          }\n        ]\n      }\n    };\n\n    function renderComparison(key) {\n      const data = comparisons[key];\n      if (!data) return;\n\n      compareImage.src = data.image;\n      compareImage.alt = data.alt;\n\n      compareGrid.innerHTML = data.rows.map((row) => `\n        <div class=\"el-compare-item\">\n          <div class=\"el-compare-icon ok\">✓</div>\n          <div class=\"el-compare-text\">${row.left}</div>\n        </div>\n        <div class=\"el-compare-item\">\n          <div class=\"el-compare-icon no\">✕</div>\n          <div class=\"el-compare-text\">${row.right}</div>\n        </div>\n      `).join(\"\");\n    }\n\n    compareSelect.addEventListener(\"change\", function () {\n      renderComparison(this.value);\n    });\n\n    renderComparison(\"rasoir\");\n  })();\n</script>",
