ls>\n\n  <details>\n    <summary>\n      <span class=\"faq-q\">Que contient le pack ELINEA ?</span>\n      <span class=\"faq-btn\">+</span>\n    </summary>\n    <div class=\"eline-content\">\n      <ul>\n        <li>Tête de tonte corps</li>\n        <li>Tête de précision</li>\n        <li>Sabot</li>\n        <li>Câble de chargement USB-C</li>\n        <li>Brosse de nettoyage</li>\n        <li>Manuel d’utilisation</li>\n        <li><strong>E-book offert</strong></li>\n      </ul>\n    </div>\n  </details>\n\n  <details>\n    <summary>\n      <span class=\"faq-q\">Conseils d’utilisation</span>\n      <span class=\"faq-btn\">+</span>\n    </summary>\n    <div class=\"eline-content\">\n      <p><strong>Avant :</strong> exfolier la peau 24h avant.</p>\n      <p><strong>Pendant :</strong> angle ~30°, pression légère.</p>\n      <p><strong>Après :</strong> soin apaisant sans alcool.</p>\n    </div>\n  </details>\n\n  <details>\n    <summary>\n      <span class=\"faq-q\">Expédition</span>\n      <span class=\"faq-btn\">+</span>\n    </summary>\n    <div class=\"eline-content\">\n      <p>\n        Commande passée aujourd’hui (<strong><span data-today></span></strong>)\n        avant <strong>minuit</strong> : expédition <strong>le jour même</strong>.\n      </p>\n    </div>\n  </details>\n\n  <details>\n    <summary>\n      <span class=\"faq-q\">Garantie 30 jours Satisfait ou Remboursé</span>\n      <span class=\"faq-btn\">+</span>\n    </summary>\n    <div class=\"eline-content\">\n      <p>Essayez ELINEA pendant 30 jours.</p>\n      <p>Remboursement intégral si vous n’êtes pas satisfait.</p>\n    </div>\n  </details>\n\n</div>\n\n<script>\n(() => {\n  const items = document.querySelectorAll('#elineFaq details');\n\n  items.forEach(d => {\n    const btn = d.querySelector('.faq-btn');\n\n    d.addEventListener('toggle', () => {\n      items.forEach(o => {\n        const b = o.querySelector('.faq-btn');\n        if(o === d && o.open){\n          b.textContent = '−';\n        } else {\n          o.removeAttribute('open');\n          b.textContent = '+';\n        }\n      });\n    });\n  });\n\n  const today = new Date();\n  const fmt = today.toLocaleDateString('fr-FR', {\n    weekday:'long',\n    year:'numeric',\n    month:'long',\n    day:'numeric'\n  });\n\n  document.querySelectorAll('[data-today]')\n    .forEach(el => el.textContent = fmt);\n})();\n</script>"
