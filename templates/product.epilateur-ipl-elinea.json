55;\n    margin:0 0 12px;\n  }\n\n  .elxR-bullets{\n    list-style:none;\n    padding:0;\n    margin:0;\n    display:grid;\n    gap:8px;\n  }\n\n  .elxR-bullets li{\n    display:flex;\n    align-items:flex-start;\n    gap:8px;\n    font-size:13px;\n    line-height:1.4;\n    color:#111;\n  }\n\n  .elxR-check{\n    flex:0 0 auto;\n    font-weight:700;\n  }\n\n  .elxR-bullets strong{\n    font-weight:700;\n  }\n\n  @media (max-width:380px){\n    .elxR-title{\n      font-size:22px;\n    }\n\n    .elxR-toprow{\n      flex-direction:column;\n      align-items:flex-start;\n    }\n\n    .elxR-dots{\n      padding-left:0;\n    }\n  }\n</style>\n\n<section class=\"elxR-banner\" data-elx-reviews>\n\n  <div class=\"elxR-toprow\">\n    <div class=\"elxR-ratingWrap\">\n      <span class=\"elxR-stars\">★★★★★</span>\n      <span class=\"elxR-rating\">4.8 · 1 800+ avis</span>\n    </div>\n    <div class=\"elxR-flag\">🇫🇷 Marque française</div>\n  </div>\n\n  <div class=\"elxR-quote\">\n    <div class=\"elxR-quoteTop\">\n      <img class=\"avatar\" data-elx-avatar src=\"https://i.pravatar.cc/84?img=15\" alt=\"Avis client\">\n      <div class=\"elxR-quoteText\">\n        <p class=\"qtitle\" data-elx-quote>Après quelques séances, mes poils repoussent beaucoup moins vite.</p>\n        <p class=\"qmeta\" data-elx-meta></p>\n      </div>\n    </div>\n\n    <div class=\"elxR-dots\" aria-label=\"Avis clients\">\n      <span class=\"elxR-dot active\" data-idx=\"0\" role=\"button\" tabindex=\"0\" aria-label=\"Avis 1\"></span>\n      <span class=\"elxR-dot\" data-idx=\"1\" role=\"button\" tabindex=\"0\" aria-label=\"Avis 2\"></span>\n      <span class=\"elxR-dot\" data-idx=\"2\" role=\"button\" tabindex=\"0\" aria-label=\"Avis 3\"></span>\n    </div>\n  </div>\n\n  <h2 class=\"elxR-title\">Épilateur IPL Elinea</h2>\n  <p class=\"elxR-subtitle\">Réduisez durablement la repousse des poils à la maison, en toute simplicité.</p>\n\n  <ul class=\"elxR-bullets\">\n    <li><span class=\"elxR-check\">✓</span><span><strong>Réduction durable</strong> de la repousse</span></li>\n    <li><span class=\"elxR-check\">✓</span><span><strong>Technologie glacée</strong> plus confortable</span></li>\n    <li><span class=\"elxR-check\">✓</span><span><strong>5 intensités</strong> selon votre peau</span></li>\n  </ul>\n\n</section>\n\n<script>\n(function(){\n  const section = document.querySelector('[data-elx-reviews]');\n  if(!section) return;\n\n  const quoteEl = section.querySelector('[data-elx-quote]');\n  const metaEl = section.querySelector('[data-elx-meta]');\n  const avatarEl = section.querySelector('[data-elx-avatar]');\n  const dots = section.querySelectorAll('.elxR-dot');\n\n  const slides = [\n    {\n      quote:\"Après quelques séances, mes poils repoussent beaucoup moins vite.\",\n      name:\"Claire M.\",\n      city:\"Paris\",\n      days:6,\n      avatar:\"https://i.pravatar.cc/84?img=15\"\n    },\n    {\n      quote:\"Le mode glacé rend l’utilisation beaucoup plus confortable.\",\n      name:\"Sophie L.\",\n      city:\"Lyon\",\n      days:12,\n      avatar:\"https://i.pravatar.cc/84?img=28\"\n    },\n    {\n      quote:\"Simple à utiliser et résultats visibles sur les jambes.\",\n      name:\"Émilie R.\",\n      city:\"Nice\",\n      days:3,\n      avatar:\"https://i.pravatar.cc/84?img=45\"\n    }\n  ];\n\n  let current = 0;\n  let autoSlide;\n\n  function render(i){\n    const s = slides[i];\n    quoteEl.textContent = s.quote;\n    metaEl.textContent = s.name + \" · \" + s.city + \" · il y a \" + s.days + \" jours\";\n    avatarEl.src = s.avatar;\n    avatarEl.alt = \"Avis de \" + s.name;\n    dots.forEach((dot, idx) => dot.classList.toggle(\"active\", idx === i));\n    current = i;\n  }\n\n  function goTo(idx){\n    const i = Number(idx);\n    if(Number.isNaN(i)) return;\n    render(i);\n    restartAuto();\n  }\n\n  function startAuto(){\n    autoSlide = setInterval(() => {\n      render((current + 1) % slides.length);\n    }, 3500);\n  }\n\n  function restartAuto(){\n    clearInterval(autoSlide);\n    startAuto();\n  }\n\n  dots.forEach(dot => {\n    dot.addEventListener(\"click\", () => goTo(dot.dataset.idx));\n    dot.addEventListener(\"keydown\", (e) => {\n      if(e.key === \"Enter\" || e.key === \" \"){\n        e.preventDefault();\n        goTo(dot.dataset.idx);\n      }\n    });\n  });\n\n  render(0);\n  startAuto();\n})();\n</script>"
