            "liquid": "<!-- =========================================================\nBANNIÈRE AVIS (AUTO + DOTS) - MOBILE FRIENDLY\n========================================================= -->\n\n<style>\n  .elxR-banner{\n    font-family:-apple-system,BlinkMacSystemFont,\"Helvetica Neue\",Arial,sans-serif;\n    max-width:980px;margin:18px auto;padding:0 16px;color:#111;\n  }\n\n  .elxR-toprow{\n    display:flex;align-items:center;justify-content:space-between;\n    gap:12px;flex-wrap:wrap;margin-bottom:12px;\n  }\n\n  .elxR-reviews-link{display:inline-flex;align-items:center;gap:10px;color:#111;font-size:14px;font-weight:600;}\n  .elxR-reviews-link a{color:#111;text-decoration:underline;}\n  .elxR-stars{color:#22a06b;letter-spacing:2px;font-size:14px;display:inline-flex;align-items:center;gap:8px;}\n  .elxR-rating{font-size:13px;font-weight:700;color:#111;}\n  .elxR-flag{display:inline-flex;align-items:center;gap:8px;font-size:14px;font-weight:600;white-space:nowrap;}\n\n  .elxR-quote{\n    background:#f6f0e7;border:1px solid rgba(0,0,0,.08);\n    border-radius:12px;padding:12px 12px;\n    display:flex;align-items:flex-start;gap:10px;\n    position:relative;margin-bottom:12px;\n  }\n\n  .elxR-quote .avatar{\n    width:40px;height:40px;border-radius:999px;object-fit:cover;\n    border:1px solid rgba(0,0,0,.08);flex:0 0 auto;\n  }\n\n  .elxR-quote .qwrap{min-width:0; padding-right:56px;} /* réserve place pour les dots */\n  .elxR-quote .qtitle{\n    font-weight:700;font-size:14px;line-height:1.25;margin:0 0 4px;\n    word-break:break-word;\n  }\n  .elxR-quote .qmeta{font-size:12.5px;color:#555;margin:0;line-height:1.2;}\n\n  .elxR-dots{\n    display:flex;gap:7px;\n    position:absolute;right:12px;top:50%;\n    transform:translateY(-50%);\n  }\n  .elxR-dot{width:7px;height:7px;border-radius:50%;background:rgba(0,0,0,.25);cursor:pointer;}\n  .elxR-dot.active{background:rgba(0,0,0,.85);}\n\n  .elxR-title{\n    font-family:Georgia,\"Times New Roman\",serif;\n    font-s