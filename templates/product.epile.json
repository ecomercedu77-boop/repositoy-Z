        "liquid": "<style>\n.elx-quiz-wrap{\nbackground:#f4f4f4;\npadding:38px 14px;\nfont-family:-apple-system,BlinkMacSystemFont,\"Helvetica Neue\",Arial,sans-serif;\ntext-align:center;\n}\n\n.elx-title{\nfont-size:34px;\nfont-weight:800;\nline-height:1.15;\nmargin:0 0 28px;\nletter-spacing:-0.5px;\ncolor:#111;\n}\n\n.elx-sub{\nfont-size:15px;\nmargin-bottom:18px;\ncolor:#222;\n}\n\n.elx-step{display:none}\n.elx-step.active{display:block}\n\n.elx-options{\ndisplay:flex;\njustify-content:center;\ngap:14px;\nflex-wrap:wrap;\nmargin-bottom:26px;\n}\n\n.elx-option{\nborder:none;\nbackground:none;\ncursor:pointer;\npadding:0;\n}\n\n.elx-circle{\nwidth:62px;\nheight:62px;\nborder-radius:50%;\nborder:3px solid transparent;\ntransition:.2s ease;\nbox-sizing:border-box;\n}\n\n.elx-option.selected .elx-circle{\nborder-color:#222;\nbox-shadow:0 0 0 5px rgba(239,183,193,.65);\n}\n\n.elx-progress{\ndisplay:flex;\njustify-content:center;\ngap:10px;\nmargin-top:6px;\n}\n\n.elx-progress button{\nwidth:38px;\nheight:38px;\nborder-radius:50%;\nborder:2px solid #222;\nbackground:#fff;\nfont-size:16px;\nfont-weight:700;\ncolor:#222;\n}\n\n.elx-progress .active{\nbackground:#efb7c1;\nborder-color:#efb7c1;\ncolor:#fff;\n}\n\n.elx-result-avatar{\nwidth:86px;\nheight:86px;\nborder-radius:50%;\nobject-fit:cover;\nmargin:10px auto 18px;\ndisplay:block;\nbox-shadow:0 6px 18px rgba(0,0,0,.08);\n}\n\n.elx-result-text{\nfont-size:15px;\nline-height:1.55;\nmargin:0 auto 18px;\nmax-width:340px;\ncolor:#111;\n}\n\n.elx-actions{\ndisplay:flex;\nflex-direction:column;\ngap:10px;\nalign-items:center;\nmargin-top:8px;\n}\n\n.elx-btn{\nwidth:100%;\nmax-width:280px;\npadding:14px 18px;\nborder-radius:10px;\nfont-weight:800;\ntext-transform:uppercase;\nletter-spacing:1px;\ncursor:pointer;\nborder:none;\nfont-size:13px;\n}\n\n.elx-btn-pink{\nbackground:#efb7c1;\ncolor:#fff;\nborder:2px solid #111;\n}\n\n.elx-btn-black{\nbackground:#111;\ncolor:#fff;\nborder:2px solid #111;\n}\n\n.elx-mini{\nfont-size:12px;\ncolor:#777;\nmargin-top:14px;\nline-height:1.4;\nmax-width:320px;\nmargin-left:auto;\nmargin-right:auto;\n}\n</style>\n\n<section class=\"elx-quiz-wrap\">\n\n<h2 class=\"elx-title\">\nEst-ce que l'Épilateur Elinea est fait pour moi ?\n</h2>\n\n<!-- STEP 1 -->\n<div class=\"elx-step active\" id=\"step1\">\n  <p class=\"elx-sub\">Sélectionnez la couleur de votre peau</p>\n\n  <div class=\"elx-options\" id=\"skinOptions\">\n    <button class=\"elx-option\" data-skin=\"1\"><div class=\"elx-circle\" style=\"background:#ead9c7\"></div></button>\n    <button class=\"elx-option\" data-skin=\"2\"><div class=\"elx-circle\" style=\"background:#ddb99f\"></div></button>\n    <button class=\"elx-option\" data-skin=\"3\"><div class=\"elx-circle\" style=\"background:#c99668\"></div></button>\n    <button class=\"elx-option\" data-skin=\"4\"><div class=\"elx-circle\" style=\"background:#8a6445\"></div></button>\n    <button class=\"elx-option\" data-skin=\"5\"><div class=\"elx-circle\" style=\"background:#744c33\"></div></button>\n  </div>\n\n  <div class=\"elx-progress\">\n    <button class=\"active\">1</button>\n    <button disabled>2</button>\n    <button disabled>3</button>\n  </div>\n</div>\n\n<!-- STEP 2 -->\n<div class=\"elx-step\" id=\"step2\">\n  <p class=\"elx-sub\">Sélectionnez la couleur de vos poils</p>\n\n  <div class=\"elx-options\" id=\"hairOptions\">\n    <button class=\"elx-option\" data-hair=\"blond\"><div class=\"elx-circle\" style=\"background:#e8d7c2\"></div></button>\n    <button class=\"elx-option\" data-hair=\"gris\"><div class=\"elx-circle\" style=\"background:#d9d9d9\"></div></button>\n    <button class=\"elx-option\" data-hair=\"brun\"><div class=\"elx-circle\" style=\"background:#8b5e3c\"></div></button>\n    <button class=\"elx-option\" data-hair=\"auburn\"><div class=\"elx-circle\" style=\"background:#a95543\"></div></button>\n    <button class=\"elx-option\" data-hair=\"noir\"><div class=\"elx-circle\" style=\"background:#111\"></div></button>\n  </div>\n\n  <div class=\"elx-progress\">\n    <button id=\"back1\">1</button>\n    <button class=\"active\">2</button>\n    <button disabled>3</button>\n  </div>\n</div>\n\n<!-- STEP 3 -->\n<div class=\"elx-step\" id=\"step3\">\n  <img\n    class=\"elx-result-avatar\"\n    src=\"https://images.unsplash.com/photo-1524504388940-b1c1722653e1?auto=format&fit=crop&w=300&q=80\"\n    id=\"resultAvatar\"\n    alt=\"Résultat\"\n  >\n\n  <p class=\"elx-result-text\" id=\"resultText\">\n    Bonne nouvelle ! Votre profil semble compatible avec l'Épilateur Elinea.\n  </p>\n\n  <div class=\"elx-actions\">\n    <button class=\"elx-btn elx-btn-pink\" id=\"restart\">\n      Recommencer\n    </button>\n\n    <a href=\"/products/epile\" style=\"width:100%;max-width:280px;text-decoration:none;\">\n      <button class=\"elx-btn elx-btn-black\" style=\"width:100%;\">\n        Voir l'épilateur\n      </button>\n    </a>\n  </div>\n\n  <div class=\"elx-progress\" style=\"margin-top:18px;\">\n    <button id=\"back2\">1</button>\n    <button id=\"back3\">2</button>\n    <button class=\"active\">3</button>\n  </div>\n\n  <div class=\"elx-mini\">\n    Ce test est indicatif et conçu pour vous aider à choisir plus sereinement.\n  </div>\n</div>\n\n</section>\n\n<script>\nlet skin = null;\nlet hair = null;\n\nconst step1 = document.getElementById(\"step1\");\nconst step2 = document.getElementById(\"step2\");\nconst step3 = document.getElementById(\"step3\");\n\nconst resultText = document.getElementById(\"resultText\");\nconst resultAvatar = document.getElementById(\"resultAvatar\");\n\ndocument.querySelectorAll(\"#skinOptions .elx-option\").forEach(btn => {\n  btn.onclick = function(){\n    skin = this.dataset.skin;\n    document.querySelectorAll(\"#skinOptions .elx-option\").forEach(b => b.classList.remove(\"selected\"));\n    this.classList.add(\"selected\");\n    setTimeout(() => {\n      step1.classList.remove(\"active\");\n      step2.classList.add(\"active\");\n    }, 250);\n  }\n});\n\ndocument.querySelectorAll(\"#hairOptions .elx-option\").forEach(btn => {\n  btn.onclick = function(){\n    hair = this.dataset.hair;\n    document.querySelectorAll(\"#hairOptions .elx-option\").forEach(b => b.classList.remove(\"selected\"));\n    this.classList.add(\"selected\");\n    showResult();\n  }\n});\n\nfunction showResult(){\n  if(hair === \"noir\"){\n    resultAvatar.src = \"https://images.unsplash.com/photo-1488426862026-3ee34a7d66df?auto=format&fit=crop&w=300&q=80\";\n    resultText.innerText = \"Excellente nouvelle ! Votre profil semble particulièrement bien adapté à l'Épilateur Elinea.\";\n  }\n  else if(hair === \"brun\"){\n    resultAvatar.src = \"https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=300&q=80\";\n    resultText.innerText = \"Bonne nouvelle ! De nombreuses utilisatrices avec un profil proche du vôtre obtiennent une peau plus lisse avec l'Épilateur Elinea.\";\n  }\n  else if(hair === \"auburn\"){\n    resultAvatar.src = \"https://images.unsplash.com/photo-1517841905240-472988babdf9?auto=format&fit=crop&w=300&q=80\";\n    resultText.innerText = \"Bonne nouvelle ! L'Épilateur Elinea peut parfaitement s'intégrer dans votre routine beauté.\";\n  }\n  else if(hair === \"blond\"){\n    resultAvatar.src = \"https://images.unsplash.com/photo-1544005313-94ddf0286df2?auto=format&fit=crop&w=300&q=80\";\n    resultText.innerText = \"Bonne nouvelle ! Beaucoup d'utilisatrices avec un profil similaire utilisent déjà l'Épilateur Elinea.\";\n  }\n  else{\n    resultAvatar.src = \"https://images.unsplash.com/photo-1529626455594-4ff0802cfb7e?auto=format&fit=crop&w=300&q=80\";\n    resultText.innerText = \"Bonne nouvelle ! Votre profil est compatible avec l'Épilateur Elinea.\";\n  }\n\n  step2.classList.remove(\"active\");\n  step3.classList.add(\"active\");\n}\n\ndocument.getElementById(\"back1\").onclick = () => {\n  step2.classList.remove(\"active\");\n  step1.classList.add(\"active\");\n};\n\ndocument.getElementById(\"back2\").onclick = () => {\n  step3.classList.remove(\"active\");\n  step1.classList.add(\"active\");\n};\n\ndocument.getElementById(\"back3\").onclick = () => {\n  step3.classList.remove(\"active\");\n  step2.classList.add(\"active\");\n};\n\ndocument.getElementById(\"restart\").onclick = () => location.reload();\n</script>",
