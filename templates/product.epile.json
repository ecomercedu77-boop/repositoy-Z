        "remove_horizontal_spacing": false,
        "liquid": "<style>\n  .elx-premium-quiz{\n    background:#f5f5f5;\n    padding:80px 20px;\n    font-family:-apple-system,BlinkMacSystemFont,\"Helvetica Neue\",Arial,sans-serif;\n    color:#111;\n    overflow:hidden;\n  }\n\n  .elx-premium-inner{\n    max-width:1320px;\n    margin:0 auto;\n    text-align:center;\n  }\n\n  .elx-premium-kicker{\n    font-size:18px;\n    font-weight:500;\n    margin-bottom:10px;\n    color:#111;\n  }\n\n  .elx-premium-title{\n    margin:0 0 64px;\n    font-size:72px;\n    line-height:1.02;\n    font-weight:800;\n    letter-spacing:-1.8px;\n    color:#000;\n  }\n\n  .elx-step{\n    display:none;\n  }\n\n  .elx-step.active{\n    display:block;\n  }\n\n  .elx-step-label{\n    font-size:18px;\n    font-weight:500;\n    margin-bottom:34px;\n    color:#111;\n  }\n\n  .elx-options{\n    display:flex;\n    justify-content:center;\n    gap:54px;\n    flex-wrap:wrap;\n    margin-bottom:48px;\n  }\n\n  .elx-option{\n    border:none;\n    background:transparent;\n    padding:0;\n    cursor:pointer;\n    transition:transform .18s ease;\n  }\n\n  .elx-option:hover{\n    transform:translateY(-3px);\n  }\n\n  .elx-bubble{\n    width:146px;\n    height:146px;\n    border-radius:999px;\n    border:4px solid transparent;\n    box-sizing:border-box;\n    transition:all .18s ease;\n    box-shadow:0 0 0 0 rgba(239,183,193,0);\n    overflow:hidden;\n  }\n\n  .elx-option.selected .elx-bubble{\n    border-color:#232323;\n    box-shadow:0 0 0 9px rgba(239,183,193,.6);\n  }\n\n  .elx-progress{\n    display:flex;\n    justify-content:center;\n    align-items:center;\n    gap:16px;\n    margin-top:8px;\n  }\n\n  .elx-progress-dot{\n    width:50px;\n    height:50px;\n    border-radius:999px;\n    border:2px solid #222;\n    display:flex;\n    align-items:center;\n    justify-content:center;\n    background:#fff;\n    color:#222;\n    font-size:24px;\n    cursor:pointer;\n    box-sizing:border-box;\n  }\n\n  .elx-progress-dot.active{\n    background:#efb7c1;\n    border-color:#efb7c1;\n  }\n\n  .elx-result-avatar{\n    width:122px;\n    height:122px;\n    border-radius:999px;\n    object-fit:cover;\n    display:block;\n    margin:0 auto 28px;\n    box-shadow:0 10px 28px rgba(0,0,0,.08);\n  }\n\n  .elx-result-text{\n    max-width:1220px;\n    margin:0 auto 14px;\n    font-size:18px;\n    line-height:1.7;\n    color:#111;\n  }\n\n  .elx-result-note{\n    font-size:14px;\n    color:#6f6f6f;\n    margin-bottom:28px;\n  }\n\n  .elx-actions{\n    display:flex;\n    justify-content:center;\n    gap:18px;\n    flex-wrap:wrap;\n    margin-bottom:36px;\n  }\n\n  .elx-btn{\n    min-width:220px;\n    padding:18px 24px;\n    border-radius:10px;\n    text-decoration:none;\n    display:inline-flex;\n    justify-content:center;\n    align-items:center;\n    font-size:15px;\n    font-weight:800;\n    letter-spacing:2px;\n    text-transform:uppercase;\n    cursor:pointer;\n    transition:all .18s ease;\n    box-sizing:border-box;\n  }\n\n  .elx-btn-pink{\n    background:#efb7c1;\n    color:#fff;\n    border:2px solid #111;\n  }\n\n  .elx-btn-pink:hover{\n    opacity:.92;\n  }\n\n  .elx-btn-black{\n    background:#000;\n    color:#fff;\n    border:2px solid #000;\n  }\n\n  .elx-btn-black:hover{\n    opacity:.92;\n  }\n\n  .elx-mini{\n    font-size:13px;\n    color:#7a7a7a;\n    margin-top:6px;\n  }\n\n  @media (max-width:1100px){\n    .elx-premium-title{\n      font-size:52px;\n      margin-bottom:44px;\n    }\n\n    .elx-options{\n      gap:28px;\n    }\n\n    .elx-bubble{\n      width:118px;\n      height:118px;\n    }\n  }\n\n  @media (max-width:768px){\n    .elx-premium-quiz{\n      padding:54px 16px;\n    }\n\n    .elx-premium-title{\n      font-size:38px;\n      letter-spacing:-.8px;\n      margin-bottom:34px;\n    }\n\n    .elx-step-label{\n      font-size:16px;\n      margin-bottom:24px;\n    }\n\n    .elx-options{\n      gap:18px;\n      margin-bottom:34px;\n    }\n\n    .elx-bubble{\n      width:82px;\n      height:82px;\n    }\n\n    .elx-progress-dot{\n      width:44px;\n      height:44px;\n      font-size:20px;\n    }\n\n    .elx-result-text{\n      font-size:16px;\n      line-height:1.6;\n    }\n\n    .elx-btn{\n      min-width:180px;\n      padding:15px 18px;\n      font-size:13px;\n      letter-spacing:1.4px;\n    }\n  }\n</style>\n\n<section class=\"elx-premium-quiz\">\n  <div class=\"elx-premium-inner\">\n\n    <!-- STEP 1 -->\n    <div class=\"elx-step active\" id=\"elx-step-1\">\n      <div class=\"elx-premium-kicker\">Encore des doutes ?</div>\n      <h2 class=\"elx-premium-title\">Est-ce que l'Épilateur Elinea est fait pour moi ?</h2>\n\n      <div class=\"elx-step-label\">Sélectionnez la couleur de votre peau</div>\n\n      <div class=\"elx-options\" id=\"elx-skin-options\">\n        <button class=\"elx-option\" data-skin=\"1\" aria-label=\"Peau très claire\">\n          <div class=\"elx-bubble\" style=\"background:#e8d7c5;\"></div>\n        </button>\n\n        <button class=\"elx-option\" data-skin=\"2\" aria-label=\"Peau claire\">\n          <div class=\"elx-bubble\" style=\"background:#ddb89f;\"></div>\n        </button>\n\n        <button class=\"elx-option\" data-skin=\"3\" aria-label=\"Peau mate claire\">\n          <div class=\"elx-bubble\" style=\"background:#c99567;\"></div>\n        </button>\n\n        <button class=\"elx-option\" data-skin=\"4\" aria-label=\"Peau mate\">\n          <div class=\"elx-bubble\" style=\"background:#8d6545;\"></div>\n        </button>\n\n        <button class=\"elx-option\" data-skin=\"5\" aria-label=\"Peau foncée\">\n          <div class=\"elx-bubble\" style=\"background:#744b33;\"></div>\n        </button>\n      </div>\n\n      <div class=\"elx-progress\">\n        <button class=\"elx-progress-dot active\" type=\"button\">1</button>\n        <button class=\"elx-progress-dot\" type=\"button\" disabled>2</button>\n        <button class=\"elx-progress-dot\" type=\"button\" disabled>3</button>\n      </div>\n    </div>\n\n    <!-- STEP 2 -->\n    <div class=\"elx-step\" id=\"elx-step-2\">\n      <div class=\"elx-premium-kicker\">Encore des doutes ?</div>\n      <h2 class=\"elx-premium-title\">Est-ce que l'Épilateur Elinea est fait pour moi ?</h2>\n\n      <div class=\"elx-step-label\">Sélectionnez la couleur de vos poils à la racine</div>\n\n      <div class=\"elx-options\" id=\"elx-hair-options\">\n        <button class=\"elx-option\" data-hair=\"blond\" aria-label=\"Blond très clair\">\n          <div class=\"elx-bubble\" style=\"background:\n            repeating-linear-gradient(165deg,#e9ddc8 0 8px,#cabca5 8px 16px);\"></div>\n        </button>\n\n        <button class=\"elx-option\" data-hair=\"gris\" aria-label=\"Gris ou blanc\">\n          <div class=\"elx-bubble\" style=\"background:\n            repeating-linear-gradient(165deg,#dcdcdc 0 8px,#bdbdbd 8px 16px);\"></div>\n        </button>\n\n        <button class=\"elx-option\" data-hair=\"brun\" aria-label=\"Brun\">\n          <div class=\"elx-bubble\" style=\"background:\n            repeating-linear-gradient(165deg,#9b755a 0 8px,#7a5a47 8px 16px);\"></div>\n        </button>\n\n        <button class=\"elx-option\" data-hair=\"auburn\" aria-label=\"Auburn\">\n          <div class=\"elx-bubble\" style=\"background:\n            repeating-linear-gradient(165deg,#a95543 0 8px,#7e392f 8px 16px);\"></div>\n        </button>\n\n        <button class=\"elx-option\" data-hair=\"noir\" aria-label=\"Noir\">\n          <div class=\"elx-bubble\" style=\"background:\n            repeating-linear-gradient(165deg,#131313 0 8px,#202020 8px 16px);\"></div>\n        </button>\n      </div>\n\n      <div class=\"elx-progress\">\n        <button class=\"elx-progress-dot\" type=\"button\" id=\"elx-back-1\">1</button>\n        <button class=\"elx-progress-dot active\" type=\"button\">2</button>\n        <button class=\"elx-progress-dot\" type=\"button\" disabled>3</button>\n      </div>\n    </div>\n\n    <!-- STEP 3 -->\n    <div class=\"elx-step\" id=\"elx-step-3\">\n      <div class=\"elx-premium-kicker\">Encore des doutes ?</div>\n      <h2 class=\"elx-premium-title\">Est-ce que l'Épilateur Elinea est fait pour moi ?</h2>\n\n      <img\n        class=\"elx-result-avatar\"\n        src=\"https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=300&q=80\"\n        alt=\"Résultat compatibilité Elinea\"\n      >\n\n      <p class=\"elx-result-text\" id=\"elx-result-text\">\n        Oui ! En fonction de votre carnation et de la couleur de vos poils, l'Épilateur Elinea devrait parfaitement vous convenir. Commandez dès maintenant et préparez-vous à une peau douce et lisse plus longtemps.\n      </p>\n\n      <div class=\"elx-result-note\" id=\"elx-result-note\"></div>\n\n      <div class=\"elx-actions\">\n        <button class=\"elx-btn elx-btn-pink\" type=\"button\" id=\"elx-restart\">\n          Recommencer\n        </button>\n        <a class=\"elx-btn elx-btn-black\" href=\"/products/epile\">\n          Voir nos produits\n        </a>\n      </div>\n\n      <div class=\"elx-progress\">\n        <button class=\"elx-progress-dot\" type=\"button\" id=\"elx-back-to1\">1</button>\n        <button class=\"elx-progress-dot\" type=\"button\" id=\"elx-back-to2\">2</button>\n        <button class=\"elx-progress-dot active\" type=\"button\">3</button>\n      </div>\n\n      <div class=\"elx-mini\">Ce test est indicatif et basé sur les profils généralement les plus compatibles.</div>\n    </div>\n\n  </div>\n</section>\n\n<script>\n(function(){\n  let selectedSkin = null;\n  let selectedHair = null;\n\n  const step1 = document.getElementById('elx-step-1');\n  const step2 = document.getElementById('elx-step-2');\n  const step3 = document.getElementById('elx-step-3');\n\n  const skinOptions = document.querySelectorAll('#elx-skin-options .elx-option');\n  const hairOptions = document.querySelectorAll('#elx-hair-options .elx-option');\n\n  const resultText = document.getElementById('elx-result-text');\n  const resultNote = document.getElementById('elx-result-note');\n\n  function showStep(step){\n    step1.classList.remove('active');\n    step2.classList.remove('active');\n    step3.classList.remove('active');\n\n    if(step === 1) step1.classList.add('active');\n    if(step === 2) step2.classList.add('active');\n    if(step === 3) step3.classList.add('active');\n  }\n\n  function selectOnly(list, current){\n    list.forEach(item => item.classList.remove('selected'));\n    current.classList.add('selected');\n  }\n\n  function setResult(){\n    const skin = parseInt(selectedSkin, 10);\n    const hair = selectedHair;\n    const strongHair = ['brun', 'auburn', 'noir'];\n    const weakHair = ['blond', 'gris'];\n\n    if (skin <= 3 && strongHair.includes(hair)) {\n      resultText.textContent =\n        \"Oui ! En fonction de votre carnation et de la couleur de vos poils, l'Épilateur Elinea devrait parfaitement vous convenir. Votre profil est particulièrement favorable pour obtenir des résultats visibles et durables.\";\n      resultNote.textContent =\n        \"Compatibilité élevée : peau claire à mate claire + poils foncés.\";\n      return;\n    }\n\n    if (skin === 4 && strongHair.includes(hair)) {\n      resultText.textContent =\n        \"L'Épilateur Elinea peut convenir à votre profil, notamment si vos poils sont bien foncés. Les résultats peuvent varier selon les zones, mais votre profil reste globalement compatible.\";\n      resultNote.textContent =\n        \"Compatibilité moyenne à bonne : peau mate + poils foncés.\";\n      return;\n    }\n\n    if (skin === 5 || weakHair.includes(hair)) {\n      resultText.textContent =\n        \"Votre profil semble moins favorable pour ce type de technologie, notamment si vos poils sont très clairs, gris ou si votre carnation est très foncée. Dans ce cas, les résultats peuvent être plus limités.\";\n      resultNote.textContent =\n        \"Compatibilité réduite : poils très clairs / gris ou peau très foncée.\";\n      return;\n    }\n\n    resultText.textContent =\n      \"Votre profil semble compatible avec l'Épilateur Elinea. Les résultats peuvent varier selon votre pilosité, mais vous avez de bonnes chances d'obtenir une peau plus nette et plus douce dans le temps.\";\n    resultNote.textContent =\n      \"Compatibilité correcte.\";\n  }\n\n  skinOptions.forEach(btn => {\n    btn.addEventListener('click', function(){\n      selectedSkin = this.dataset.skin;\n      selectOnly(skinOptions, this);\n      setTimeout(() => showStep(2), 220);\n    });\n  });\n\n  hairOptions.forEach(btn => {\n    btn.addEventListener('click', function(){\n      selectedHair = this.dataset.hair;\n      selectOnly(hairOptions, this);\n      setResult();\n      setTimeout(() => showStep(3), 220);\n    });\n  });\n\n  document.getElementById('elx-back-1').addEventListener('click', function(){\n    showStep(1);\n  });\n\n  document.getElementById('elx-back-to1').addEventListener('click', function(){\n    showStep(1);\n  });\n\n  document.getElementById('elx-back-to2').addEventListener('click', function(){\n    showStep(2);\n  });\n\n  document.getElementById('elx-restart').addEventListener('click', function(){\n    selectedSkin = null;\n    selectedHair = null;\n    skinOptions.forEach(item => item.classList.remove('selected'));\n    hairOptions.forEach(item => item.classList.remove('selected'));\n    resultNote.textContent = '';\n    showStep(1);\n  });\n})();\n</script>",
