    "ugc_reviews_strip": {
      "type": "custom-liquid",
      "settings": {
        "full_width": true,
        "remove_vertical_spacing": false,
        "remove_horizontal_spacing": false,
        "liquid": "<style>\n\n.urs{\npadding:32px 16px;\nbackground:#fff;\noverflow:hidden;\n}\n\n.urs h2{\nfont-size:1.3rem;\nfont-weight:900;\ncolor:#111;\nmargin:0 0 6px;\ntext-align:center;\n}\n\n.urs-sub{\ntext-align:center;\nfont-size:.82rem;\ncolor:#888;\nmargin:0 0 20px;\n}\n\n.urs-grid{\ndisplay:flex;\ngap:14px;\noverflow-x:auto;\nscroll-snap-type:x mandatory;\npadding-bottom:10px;\n}\n\n.urs-grid::-webkit-scrollbar{\ndisplay:none;\n}\n\n.ur-card{\nmin-width:85%;\nscroll-snap-align:center;\nbackground:#fafafa;\nborder:1px solid #f0e0e8;\nborder-radius:16px;\npadding:16px;\n}\n\n.ur-top{\ndisplay:flex;\nalign-items:center;\ngap:10px;\nmargin-bottom:10px;\n}\n\n.ur-av{\nwidth:44px;\nheight:44px;\nborder-radius:50%;\nobject-fit:cover;\n}\n\n.ur-name{\nfont-size:.88rem;\nfont-weight:900;\ncolor:#111;\n}\n\n.ur-meta{\nfont-size:.72rem;\ncolor:#aaa;\nfont-weight:700;\n}\n\n.ur-stars{\ncolor:#f5c842;\nfont-size:.82rem;\nmargin-bottom:6px;\n}\n\n.ur-text{\nfont-size:.85rem;\ncolor:#444;\nline-height:1.6;\nfont-style:italic;\n}\n\n</style>\n\n\n<div class=\"urs\">\n\n<h2>Elles l'ont testé. Elles ont adoré.</h2>\n\n<p class=\"urs-sub\">\n⭐ 4,8/5 · 3 269 avis vérifiés · 80% donnent 5 étoiles\n</p>\n\n\n<div class=\"urs-grid\" id=\"reviewSlider\">\n\n<!-- AVIS 1 -->\n<div class=\"ur-card\">\n<div class=\"ur-top\">\n<img class=\"ur-av\" src=\"https://www.elineap.com/cdn/shop/files/1f147f32-c747-4aae-a885-7c862bbde932.png?v=1769563375\"/>\n<div>\n<div class=\"ur-name\">Clara L. — Lyon</div>\n<div class=\"ur-meta\">✓ Achat vérifié · Il y a 5 jours</div>\n</div>\n</div>\n<div class=\"ur-stars\">★★★★★</div>\n<p class=\"ur-text\">\n\"Je l'utilise depuis 3 semaines, résultat bluffant ! Plus de duvet visible, peau incroyablement douce.\"\n</p>\n</div>\n\n\n<!-- AVIS 2 -->\n<div class=\"ur-card\">\n<div class=\"ur-top\">\n<img class=\"ur-av\" src=\"https://www.elineap.com/cdn/shop/files/4ddd4141-b2d3-41de-ad73-0aaac69d981b.png?v=1769563374\"/>\n<div>\n<div class=\"ur-name\">Joséphine C. — Paris</div>\n<div class=\"ur-meta\">✓ Achat vérifié · Il y a 11 jours</div>\n</div>\n</div>\n<div class=\"ur-stars\">★★★★★</div>\n<p class=\"ur-text\">\n\"Enfin une solution douce ! Zéro rougeur, zéro irritation. Ma peau est nickel.\"\n</p>\n</div>\n\n\n<!-- AVIS 3 -->\n<div class=\"ur-card\">\n<div class=\"ur-top\">\n<img class=\"ur-av\" src=\"https://www.elineap.com/cdn/shop/files/c108b55b-682f-4ef3-99a9-1e904e963e95.png?v=1769563374\"/>\n<div>\n<div class=\"ur-name\">Laurine H. — Bordeaux</div>\n<div class=\"ur-meta\">✓ Achat vérifié · Il y a 18 jours</div>\n</div>\n</div>\n<div class=\"ur-stars\">★★★★★</div>\n<p class=\"ur-text\">\n\"Repousse ralentie et plus fine. En 2 utilisations j'ai déjà vu une différence.\"\n</p>\n</div>\n\n\n<!-- AVIS 4 -->\n<div class=\"ur-card\">\n<div class=\"ur-top\">\n<img class=\"ur-av\" src=\"https://www.elineap.com/cdn/shop/files/0be8ce6b-4bc0-4e95-a6f1-437717de5b2a.png?v=1769563373\"/>\n<div>\n<div class=\"ur-name\">Ludivine L. — Marseille</div>\n<div class=\"ur-meta\">✓ Achat vérifié · Il y a 22 jours</div>\n</div>\n</div>\n<div class=\"ur-stars\">★★★★★</div>\n<p class=\"ur-text\">\n\"En une utilisation, plus de duvet. Vraiment indolore.\"\n</p>\n</div>\n\n\n<!-- AVIS 5 -->\n<div class=\"ur-card\">\n<div class=\"ur-top\">\n<img class=\"ur-av\" src=\"https://www.elineap.com/cdn/shop/files/hi1.webp?v=1769563365\"/>\n<div>\n<div class=\"ur-name\">Ambre D. — Nantes</div>\n<div class=\"ur-meta\">✓ Achat vérifié · Il y a 29 jours</div>\n</div>\n</div>\n<div class=\"ur-stars\">★★★★★</div>\n<p class=\"ur-text\">\n\"Je dépensais 60€ en institut. Avec ELINEA+ j'ai le même résultat à la maison.\"\n</p>\n</div>\n\n\n</div>\n\n</div>\n\n\n<script>\n\nconst slider = document.getElementById(\"reviewSlider\");\n\nlet scrollAmount = 0;\n\nsetInterval(()=>{\n\nscrollAmount += slider.offsetWidth * 0.9;\n\nif(scrollAmount >= slider.scrollWidth){\nscrollAmount = 0;\n}\n\nslider.scrollTo({\nleft: scrollAmount,\nbehavior:\"smooth\"\n});\n\n},4000);\n\n</script>",
