        "liquid": "<div style=\"background:#ffffff;padding:32px 16px;overflow:hidden;position:relative;\">\n\n  <div style=\"text-align:center;margin-bottom:20px;\">\n    <span style=\"background:white;color:#c2104a;font-size:.68rem;font-weight:900;text-transform:uppercase;letter-spacing:2px;padding:5px 14px;border-radius:20px;\">\n      Photos réelles\n    </span>\n\n    <h2 style=\"font-size:1.3rem;font-weight:900;color:#111;margin:12px 0 4px;\">\n      Avant / Après sans filtre\n    </h2>\n\n    <p style=\"font-size:.82rem;color:#888;margin:0;\">\n      Résultats après 1 à 3 utilisations\n    </p>\n  </div>\n\n  <!-- bouton gauche -->\n  <button onclick=\"scrollAvantApres(-1)\" style=\"\n    position:absolute;\n    left:6px;\n    top:55%;\n    transform:translateY(-50%);\n    background:white;\n    border:none;\n    border-radius:50%;\n    width:36px;\n    height:36px;\n    font-size:18px;\n    box-shadow:0 4px 10px rgba(0,0,0,.15);\n    cursor:pointer;\n    z-index:2;\n  \">‹</button>\n\n  <!-- bouton droite -->\n  <button onclick=\"scrollAvantApres(1)\" style=\"\n    position:absolute;\n    right:6px;\n    top:55%;\n    transform:translateY(-50%);\n    background:white;\n    border:none;\n    border-radius:50%;\n    width:36px;\n    height:36px;\n    font-size:18px;\n    box-shadow:0 4px 10px rgba(0,0,0,.15);\n    cursor:pointer;\n    z-index:2;\n  \">›</button>\n\n  <div id=\"avantApresScroll\" style=\"\n    display:flex;\n    gap:14px;\n    overflow-x:auto;\n    scroll-snap-type:x mandatory;\n    padding-bottom:10px;\n    -webkit-overflow-scrolling:touch;\n  \">\n\n    <img \n      src=\"https://www.elineap.com/cdn/shop/files/avantapres1-klyne_5ff3a655-b214-4995-a0a7-02a1b1d434e2.webp?v=1772054377\"\n      style=\"flex:0 0 85%;border-radius:16px;box-shadow:0 4px 16px rgba(0,0,0,.1);scroll-snap-align:center;\"\n    />\n\n    <img \n      src=\"https://www.elineap.com/cdn/shop/files/avantapres2-klyne_70922129-1e48-4ea5-84d3-6ae7da75a021.webp?v=1772054377\"\n      style=\"flex:0 0 85%;border-radius:16px;box-shadow:0 4px 16px rgba(0,0,0,.1);scroll-snap-align:center;\"\n    />\n\n    <img \n      src=\"https://www.elineap.com/cdn/shop/files/avantapres3-klyne_3ab1d886-7e18-40eb-87b7-07d55b30ed98.webp?v=1772054377\"\n      style=\"flex:0 0 85%;border-radius:16px;box-shadow:0 4px 16px rgba(0,0,0,.1);scroll-snap-align:center;\"\n    />\n\n  </div>\n\n</div>\n\n<script>\nfunction scrollAvantApres(direction){\n  const container = document.getElementById('avantApresScroll');\n  const scrollAmount = container.clientWidth * 0.9;\n  container.scrollBy({\n    left: direction * scrollAmount,\n    behavior: 'smooth'\n  });\n}\n</script>",
