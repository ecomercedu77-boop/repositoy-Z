    box-sizing: border-box;\n  }\n\n  .elx-progress-dot.active {\n    background: #efb7c1;\n    border-color: #efb7c1;\n  }\n\n  .elx-progress-dot[disabled] {\n    cursor: default;\n    opacity: 0.6;\n  }\n\n  .elx-result-avatar {\n    width: 122px;\n    height: 122px;\n    border-radius: 999px;\n    object-fit: cover;\n    display: block;\n    margin: 0 auto 28px;\n    box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);\n  }\n\n  .elx-result-text {\n    max-width: 1220px;\n    margin: 0 auto 14px;\n    font-size: 18px;\n    line-height: 1.7;\n    color: #111;\n  }\n\n  .elx-result-note {\n    font-size: 14px;\n    color: #6f6f6f;\n    margin-bottom: 28px;\n  }\n\n  .elx-actions {\n    display: flex;\n    justify-content: center;\n    gap: 18px;\n    flex-wrap: wrap;\n    margin-bottom: 36px;\n  }\n\n  .elx-btn {\n    min-width: 220px;\n    padding: 18px 24px;\n    border-radius: 10px;\n    text-decoration: none;\n    display: inline-flex;\n    justify-content: center;\n    align-items: center;\n    font-size: 15px;\n    font-weight: 800;\n    letter-spacing: 2px;\n    text-transform: uppercase;\n    cursor: pointer;\n    transition: all 0.18s ease;\n    box-sizing: border-box;\n  }\n\n  .elx-btn-pink {\n    background: #efb7c1;\n    color: #fff;\n    border: 2px solid #111;\n  }\n\n  .elx-btn-pink:hover {\n    opacity: 0.92;\n  }\n\n  .elx-btn-black {\n    background: #000;\n    color: #fff;\n    border: 2px solid #000;\n  }\n\n  .elx-btn-black:hover {\n    opacity: 0.92;\n  }\n\n  .elx-mini {\n    font-size: 13px;\n    color: #7a7a7a;\n    margin-top: 6px;\n  }\n\n  @media (max-width: 1100px) {\n    .elx-premium-title {\n      font-size: 52px;\n      margin-bottom: 44px;\n    }\n\n    .elx-options {\n      gap: 28px;\n    }\n\n    .elx-bubble {\n      width: 118px;\n      height: 118px;\n    }\n  }\n\n  @media (max-width: 768px) {\n    .elx-premium-quiz {\n      padding: 54px 16px;\n    }\n\n    .elx-premium-title {\n      font-size: 38px;\n      letter-spacing: -0.8px;\n      margin-bottom: 34px;\n    }\n\n    .elx-step-label {\n      font-size: 16px;\n      margin-bottom: 24px;\n    }\n\n    .elx-options {\n      gap: 18px;\n      margin-bottom: 34px;\n    }\n\n    .elx-bubble {\n      width: 82px;\n      height: 82px;\n    }\n\n    .elx-progress-dot {\n      width: 44px;\n      height: 44px;\n      font-size: 20px;\n    }\n\n    .elx-result-text {\n      font-size: 16px;\n      line-height: 1.6;\n    }\n\n    .elx-btn {\n      min-width: 180px;\n      padding: 15px 18px;\n      font-size: 13px;\n      letter-spacing: 1.4px;\n    }\n  }\n</style>\n\n<section class=\"elx-premium-quiz\">\n  <div class=\"elx-premium-inner\">\n\n    <!-- STEP 1 -->\n    <div class=\"elx-step active\" id=\"elx-step-1\">\n      <div class=\"elx-premium-kicker\">Encore des doutes ?</div>\n      <h2 class=\"elx-premium-title\">Est-ce que l'Épilateur Elinea est fait pour moi ?</h2>\n\n      <div class=\"elx-step-label\">Sélectionnez la couleur de votre peau</div>\n\n      <div class=\"elx-options\" id=\"elx-skin-options\">\n        <button class=\"elx-option\" data-skin=\"1\" type=\"button\" aria-label=\"Peau très claire\">\n          <div class=\"elx-bubble\" style=\"background:#e8d7c5;\"></div>\n        </button>\n\n        <button class=\"elx-option\" data-skin=\"2\" type=\"button\" aria-label=\"Peau claire\">\n          <div class=\"elx-bubble\" style=\"background:#ddb89f;\"></div>\n        </button>\n\n        <button class=\"elx-option\" data-skin=\"3\" type=\"button\" aria-label=\"Peau mate claire\">\n          <div class=\"elx-bubble\" style=\"background:#c99567;\"></div>\n        </button>\n\n        <button class=\"elx-option\" data-skin=\"4\" type=\"button\" aria-label=\"Peau mate\">\n          <div class=\"elx-bubble\" style=\"background:#8d6545;\"></div>\n        </button>\n\n        <button class=\"elx-option\" data-skin=\"5\" type=\"button\" aria-label=\"Peau foncée\">\n          <div class=\"elx-bubble\" style=\"background:#744b33;\"></div>\n        </button>\n      </div>\n\n      <div class=\"elx-progress\">\n        <button class=\"elx-progress-dot active\" type=\"button\">1</button>\n        <button class=\"elx-progress-dot\" type=\"button\" disabled>2</button>\n        <button class=\"elx-progress-dot\" type=\"button\" disabled>3</button>\n      </div>\n    </div>\n\n    <!-- STEP 2 -->\n    <div class=\"elx-step\" id=\"elx-step-2\">\n      <div class=\"elx-premium-kicker\">Encore des doutes ?</div>\n      <h2 class=\"elx-premium-title\">Est-ce que l'Épilateur Elinea est fait pour moi ?</h2>\n\n      <div class=\"elx-step-label\">Sélectionnez la couleur de vos poils à la racine</div>\n\n      <div class=\"elx-options\" id=\"elx-hair-options\">\n        <button class=\"elx-option\" data-hair=\"blond\" type=\"button\" aria-label=\"Blond très clair\">\n          <div class=\"elx-bubble\" style=\"background:repeating-linear-gradient(165deg,#e9ddc8 0 8px,#cabca5 8px 16px);\"></div>\n        </button>\n\n        <button class=\"elx-option\" data-hair=\"gris\" type=\"button\" aria-label=\"Gris ou blanc\">\n          <div class=\"elx-bubble\" style=\"background:repeating-linear-gradient(165deg,#dcdcdc 0 8px,#bdbdbd 8px 16px);\"></div>\n        </button>\n\n        <button class=\"elx-option\" data-hair=\"brun\" type=\"button\" aria-label=\"Brun\">\n          <div class=\"elx-bubble\" style=\"background:repeating-linear-gradient(165deg,#9b755a 0 8px,#7a5a47 8px 16px);\"></div>\n        </button>\n\n        <button class=\"elx-option\" data-hair=\"auburn\" type=\"button\" aria-label=\"Auburn\">\n          <div class=\"elx-bubble\" style=\"background:repeating-linear-gradient(165deg,#a95543 0 8px,#7e392f 8px 16px);\"></div>\n        </button>\n\n        <button class=\"elx-option\" data-hair=\"noir\" type=\"button\" aria-label=\"Noir\">\n          <div class=\"elx-bubble\" style=\"background:repeating-linear-gradient(165deg,#131313 0 8px,#202020 8px 16px);\"></div>\n        </button>\n      </div>\n\n      <div class=\"elx-progress\">\n        <button class=\"elx-progress-dot\" type=\"button\" id=\"elx-back-1\">1</button>\n        <button class=\"elx-progress-dot active\" type=\"button\">2</button>\n        <button class=\"elx-progress-dot\" type=\"button\" disabled>3</button>\n      </div>\n    </div>\n\n    <!-- STEP 3 -->\n    <div class=\"elx-step\" id=\"elx-step-3\">\n      <div class=\"elx-premium-kicker\">Encore des doutes ?</div>\n      <h2 class=\"elx-premium-title\">Est-ce que l'Épilateur Elinea est fait pour moi ?</h2>\n\n      <img\n        class=\"elx-result-avatar\"\n        src=\"https://images.unsplash.com/photo-1494790108377-be9c29b29330?auto=format&fit=crop&w=300&q=80\"\n        alt=\"Résultat compatibilité Elinea\"\n      >\n\n      <p class=\"elx-result-text\" id=\"elx-result-text\">\n        Oui ! L'Épilateur Elinea est adapté à votre profil et vous aidera à obtenir une peau plus douce, plus nette et plus lisse au fil des utilisations.\n      </p>\n\n      <div class=\"elx-result-note\" id=\"elx-result-note\">\n        Compatibilité confirmée avec l'Épilateur Elinea.\n      </div>\n\n      <div class=\"elx-actions\">\n        <button class=\"elx-btn elx-btn-pink\" type=\"button\" id=\"elx-restart\">\n          Recommencer\n        </button>\n        <a class=\"elx-btn elx-btn-black\" href=\"/products/epile\">\n          Voir nos produits\n        </a>\n      </div>\n\n      <div class=\"elx-progress\">\n        <button class=\"elx-progress-dot\" type=\"button\" id=\"elx-back-to1\">1</button>\n        <button class=\"elx-progress-dot\" type=\"button\" id=\"elx-back-to2\">2</button>\n        <button class=\"elx-progress-dot active\" type=\"button\">3</button>\n      </div>\n\n      <div class=\"elx-mini\">Ce test est indicatif et conçu pour orienter chaque profil vers une expérience positive.</div>\n    </div>\n\n  </div>\n</section>\n\n<script>\n  document.addEventListener(\"DOMContentLoaded\", function () {\n    let selectedSkin = \"\";\n    let selectedHair = \"\";\n\n    const step1 = document.getElementById(\"elx-step-1\");\n    const step2 = document.getElementById(\"elx-step-2\");\n    const step3 = document.getElementById(\"elx-step-3\");\n\n    const skinOptions = document.querySelectorAll(\"#elx-skin-options .elx-option\");\n    const hairOptions = document.querySelectorAll(\"#elx-hair-options .elx-option\");\n\n    const resultText = document.getElementById(\"elx-result-text\");\n    const resultNote = document.getElementById(\"elx-result-note\");\n\n    const back1 = document.getElementById(\"elx-back-1\");\n    const backTo1 = document.getElementById(\"elx-back-to1\");\n    const backTo2 = document.getElementById(\"elx-back-to2\");\n    const restartBtn = document.getElementById(\"elx-restart\");\n\n    function showStep(stepNumber) {\n      step1.classList.remove(\"active\");\n      step2.classList.remove(\"active\");\n      step3.classList.remove(\"active\");\n\n      if (stepNumber === 1) step1.classList.add(\"active\");\n      if (stepNumber === 2) step2.classList.add(\"active\");\n      if (stepNumber === 3) step3.classList.add(\"active\");\n    }\n\n    function selectOnly(optionsList, currentButton) {\n      optionsList.forEach(function (item) {\n        item.classList.remove(\"selected\");\n      });\n      currentButton.classList.add(\"selected\");\n    }\n\n    function setResult() {\n      const favorableMessages = [\n        {\n          text: \"Oui ! L'Épilateur Elinea est adapté à votre profil et vous aidera à obtenir une peau plus douce, plus nette et plus lisse au fil des utilisations.\",\n          note: \"Compatibilité confirmée avec l'Épilateur Elinea.\"\n        },\n        {\n          text: \"Excellente nouvelle : votre profil correspond parfaitement à l'utilisation de l'Épilateur Elinea pour une routine simple, confortable et efficace.\",\n          note: \"Profil favorable pour l'Épilateur Elinea.\"\n        },\n        {\n          text: \"Bonne nouvelle ! L'Épilateur Elinea est un très bon choix pour vous et peut vous accompagner vers des résultats visibles et une peau durablement plus douce.\",\n          note: \"Très bonne compatibilité avec l'Épilateur Elinea.\"\n        }\n      ];\n\n      let messageIndex = 0;\n\n      if (selectedSkin && selectedHair) {\n        const skinValue = parseInt(selectedSkin, 10) || 1;\n        const hairMap = {\n          blond: 0,\n          gris: 1,\n          brun: 2,\n          auburn: 1,\n          noir: 2\n        };\n\n        const hairValue = hairMap[selectedHair] !== undefined ? hairMap[selectedHair] : 0;\n        messageIndex = (skinValue + hairValue) % favorableMessages.length;\n      }\n\n      resultText.textContent = favorableMessages[messageIndex].text;\n      resultNote.textContent = favorableMessages[messageIndex].note;\n    }\n\n    skinOptions.forEach(function (btn) {\n      btn.addEventListener(\"click\", function () {\n        selectedSkin = this.dataset.skin || \"\";\n        selectOnly(skinOptions, this);\n\n        setTimeout(function () {\n          showStep(2);\n        }, 180);\n      });\n    });\n\n    hairOptions.forEach(function (btn) {\n      btn.addEventListener(\"click\", function () {\n        selectedHair = this.dataset.hair || \"\";\n        selectOnly(hairOptions, this);\n        setResult();\n\n        setTimeout(function () {\n          showStep(3);\n        }, 180);\n      });\n    });\n\n    if (back1) {\n      back1.addEventListener(\"click\", function () {\n        showStep(1);\n      });\n    }\n\n    if (backTo1) {\n      backTo1.addEventListener(\"click\", function () {\n        showStep(1);\n      });\n    }\n\n    if (backTo2) {\n      backTo2.addEventListener(\"click\", function () {\n        showStep(2);\n      });\n    }\n\n    if (restartBtn) {\n      restartBtn.addEventListener(\"click\", function () {\n        selectedSkin = \"\";\n        selectedHair = \"\";\n\n        skinOptions.forEach(function (item) {\n          item.classList.remove(\"selected\");\n        });\n\n        hairOptions.forEach(function (item) {\n          item.classList.remove(\"selected\");\n        });\n\n        resultText.textContent =\n          \"Oui ! L'Épilateur Elinea est adapté à votre profil et vous aidera à obtenir une peau plus douce, plus nette et plus lisse au fil des utilisations.\";\n\n        resultNote.textContent =\n          \"Compatibilité confirmée avec l'Épilateur Elinea.\";\n\n        showStep(1);\n      });\n    }\n  });\n</script>",
